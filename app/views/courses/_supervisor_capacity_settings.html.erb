<div data-controller="supervisor-capacity"
     data-supervisor-capacity-base-value="<%= @capacity_result.base %>"
     class="space-y-4">

  <details class="group rounded-lg border border-gray-200 bg-white shadow-sm">
    <summary
      class="cursor-pointer px-4 py-3 flex items-center justify-between gap-4 text-left text-sm font-semibold text-gray-900 list-none">
      <span>Manage Project Allocations and Lecturer exclusions</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 shrink-0 text-gray-500 transition-transform group-open:rotate-180"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>

    <div class="border-t border-gray-200 px-4 py-4 space-y-4">
      <p class="text-sm text-gray-500">
        Maximum projects and variable project allocations affect display numbers in supervisor list only, serving as a guideline. Supervisors are free to accept projects beyond the listed number.
      </p>

      <div class="flex items-start gap-3">
        <div class="flex h-5 items-center">
          <%= form.check_box :supervisor_auto_calculate_enabled,
                class: "h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500",
                data: { action: "change->supervisor-capacity#toggleAutoCalculate" } %>
        </div>
        <div>
          <%= form.label :supervisor_auto_calculate_enabled,
                "Auto-calculate based on number of groups and lecturers",
                class: "text-sm font-medium text-gray-700" %>
          <p class="text-sm text-gray-500">
            Divides total projects by eligible supervisors. Disables the manual base limit input.
          </p>
        </div>
      </div>

      <% if @lecturer_enrolments.any? %>
        <% lecturer_capacity_map = @capacity_result.lecturer_capacities.index_by { |lc| lc.enrolment.id } %>

        <div class="rounded-md border border-gray-200 overflow-hidden">
          <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left font-medium text-gray-500">Supervisor</th>
                <th class="px-4 py-3 text-center font-medium text-gray-500 whitespace-nowrap">Exclude</th>
                <th class="px-4 py-3 text-center font-medium text-gray-500 whitespace-nowrap">Offset</th>
                <th class="px-4 py-3 text-center font-medium text-gray-500 whitespace-nowrap">Relative Capacity</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-100">
              <% @lecturer_enrolments.each do |enrolment| %>
                <% lc = lecturer_capacity_map[enrolment.id] %>
                <% offset = enrolment.supervisor_capacity_offset %>
                <% effective_cap = lc&.effective_cap || 0 %>
                <% sign = offset >= 0 ? "+ #{offset}" : "- #{offset.abs}" %>
                <tr data-supervisor-capacity-target="row"
                    class="<%= 'opacity-60' if enrolment.supervisor_capacity_excluded? %>">
                  <td class="px-4 py-3 text-gray-900"><%= enrolment.user.name %></td>
                  <td class="px-4 py-3 text-center">
                    <%= check_box_tag "supervisor_capacity_excluded[]", enrolment.id,
                          enrolment.supervisor_capacity_excluded,
                          class: "h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500",
                          data: {
                            action: "change->supervisor-capacity#updateRow",
                            excluded: true
                          } %>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <%= number_field_tag "supervisor_capacity_offsets[#{enrolment.id}]",
                          offset,
                          disabled: enrolment.supervisor_capacity_excluded?,
                          class: "w-20 text-center px-2 py-1 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-green-500 focus:border-green-500",
                          data: {
                            action: "input->supervisor-capacity#updateRow",
                            offset: true
                          } %>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <span class="font-medium text-gray-900" data-result><%= effective_cap %></span>
                    <span class="text-xs text-gray-400 ml-1" data-formula>(<%= @capacity_result.base %> <%= sign %>)</span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 italic">No lecturers enrolled yet.</p>
      <% end %>
    </div>
  </details>
</div>
