<div data-controller="supervisor-capacity" class="space-y-4">

  <%# Auto-calculate %>
  <div class="flex items-start gap-3">
    <div class="flex h-5 items-center">
      <%= form.check_box :supervisor_auto_calculate_enabled,
            class: "h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500",
            data: { action: "change->supervisor-capacity#toggleAutoCalculate" } %>
    </div>
    <div>
      <%= form.label :supervisor_auto_calculate_enabled,
            "Auto-calculate based on number of groups and lecturers",
            class: "text-sm font-medium text-gray-700" %>
      <p class="text-sm text-gray-500">
        Divides total projects by eligible supervisors. Disables the manual base limit input.
      </p>
    </div>
  </div>

  <%# Variable allocations %>
  <div class="flex items-start gap-3">
    <div class="flex h-5 items-center">
      <%= form.check_box :supervisor_variable_capacity_enabled,
            class: "h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500",
            data: { action: "change->supervisor-capacity#toggle" } %>
    </div>
    <div>
      <%= form.label :supervisor_variable_capacity_enabled,
            "Enable Variable Supervisor Allocations",
            class: "text-sm font-medium text-gray-700" %>
      <p class="text-sm text-gray-500">
        Set individual offsets per supervisor on top of the base limit above.
      </p>
    </div>
  </div>

  <div data-supervisor-capacity-target="panel"
       class="<%= 'hidden' unless @course.supervisor_variable_capacity_enabled? %>">
    <% if @lecturer_enrolments.any? %>
      <div class="rounded-md border border-gray-200 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left font-medium text-gray-500 w-full">Supervisor</th>
              <th class="px-4 py-3 text-center font-medium text-gray-500 whitespace-nowrap">Offset</th>
              <th class="px-4 py-3 text-center font-medium text-gray-500 whitespace-nowrap">Relative Capacity</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-100">
            <% @lecturer_enrolments.each do |enrolment| %>
              <% offset  = enrolment.supervisor_capacity_offset %>
              <% base    = @course.supervisor_projects_limit %>
              <% eff_cap = [base + offset, 0].max %>
              <% sign    = offset >= 0 ? "+ #{offset}" : "- #{offset.abs}" %>
              <tr data-supervisor-capacity-target="row">
                <td class="px-4 py-3 text-gray-900"><%= enrolment.user.name %></td>
                <td class="px-4 py-3 text-center">
                  <%= number_field_tag "supervisor_capacity_offsets[#{enrolment.id}]",
                        offset,
                        class: "w-20 text-center px-2 py-1 border border-gray-300 rounded-md text-sm
                                focus:outline-none focus:ring-green-500 focus:border-green-500",
                        data: {
                          action: "input->supervisor-capacity#updateRow",
                          offset: true
                        } %>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="font-medium text-gray-900" data-result><%= eff_cap %></span>
                  <span class="text-xs text-gray-400 ml-1" data-formula>(<%= base %> <%= sign %>)</span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 italic">No lecturers enrolled yet.</p>
    <% end %>
  </div>

</div>
