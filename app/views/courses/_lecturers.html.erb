<li>
  <%= link_to course_lecturer_path(course, lecturer), class: "flex items-start gap-[15px] ml-2.5 mb-1.5 group no-underline w-full" do %>

    <div
      class="
        w-10 h-10 bg-[#d9d9d9] rounded-full shrink-0 flex justify-center items-center
        text-[20px] text-gray-700 font-medium
      ">
      <%= lecturer.name.first.upcase %>
    </div>

    <div class="flex-1 min-w-0">

      <div class="flex items-center gap-[30px] mb-1 text-sm font-bold">
        <div class="text-[#454343] text-base truncate">
          <%= lecturer.name %>
        </div>

        <% lecturer_capacity = @lecturer_capacity_info[lecturer.id] %>
        <% capacity_text_color =
          lecturer_capacity.at_capacity? ? "text-red-500" : "text-black" %>

        <% unless @course.solo_supervisor? %>
          <span
            class="
              text-base ml-auto pr-5 whitespace-nowrap <%= capacity_text_color %>
            ">
            <%= lecturer_capacity.approved_count %>/<%= lecturer_capacity.effective_cap %>
            <% if lecturer_capacity.pending_count > 0 %>
              <span class="text-xs font-normal text-amber-600 ml-1">
                (<%= lecturer_capacity.pending_count %>
                pending)
              </span>
            <% end %>
          </span>
        <% end %>
      </div>

      <div class="flex flex-col">
        <div class="text-xs text-[#7e7e7e]/80 my-0.5 leading-[0.7]">
          Statistics coming soon...
        </div>
        <div class="text-xs text-[#7e7e7e]/80 my-0.5 leading-[0.7]">
        </div>
      </div>

    </div>
  <% end %>
</li>
