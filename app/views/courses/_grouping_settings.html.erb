<hr class="border-gray-200">

<div
  class="space-y-6"
  data-controller="grouping-settings"
  data-grouping-settings-enabled-value="<%= @course.grouping_enabled? %>"
  data-grouping-settings-finalised-value="<%= @course.student_list_finalised? %>"
>
  <h3 class="text-lg font-medium leading-6 text-gray-900">Student Self-Grouping</h3>

  <%# ── Toggle: enable / disable ─────────────────────────────────────────── %>
  <div>
    <span class="block text-sm font-medium text-gray-700 mb-2">
      Allow students to form their own groups?
    </span>
    <div class="flex items-center space-x-4">
      <div class="flex items-center">
        <%= form.radio_button :grouping_enabled, true,
              class: "focus:ring-green-500 h-4 w-4 text-green-600 border-gray-300",
              data: { action: "change->grouping-settings#toggleEnabled" } %>
        <%= form.label :grouping_enabled, "Yes", value: true,
              class: "ml-2 block text-sm text-gray-700" %>
      </div>
      <div class="flex items-center">
        <%= form.radio_button :grouping_enabled, false,
              class: "focus:ring-green-500 h-4 w-4 text-green-600 border-gray-300",
              data: { action: "change->grouping-settings#toggleEnabled" } %>
        <%= form.label :grouping_enabled, "No", value: false,
              class: "ml-2 block text-sm text-gray-700" %>
      </div>
    </div>
  </div>

  <%# ── Options section — hidden until grouping_enabled = true ──────── %>
  <div
    data-grouping-settings-target="groupingOptions"
    class="space-y-6 pl-4 border-l-2 border-green-200"
  >

    <%# ── Mode selection ─────────────────────────────────────────────────── %>
    <div>
      <span class="block text-sm font-medium text-gray-700 mb-1">Student list mode</span>
      <p class="text-xs text-gray-500 mb-3">
        Choose whether the coordinator knows the exact final count of students.
      </p>

      <div class="space-y-3">

        <%# Default mode %>
        <label class="flex items-start gap-3 p-3 border rounded-md cursor-pointer hover:border-green-400 transition-colors
                      <%= @course.student_list_finalised? ? 'border-gray-200 bg-white' : 'border-green-500 bg-green-50' %>">
          <%= form.radio_button :student_list_finalised, false,
                class: "mt-0.5 focus:ring-green-500 h-4 w-4 text-green-600 border-gray-300 shrink-0",
                data: { action: "change->grouping-settings#toggleMode" } %>
          <div>
            <span class="block text-sm font-medium text-gray-800">Default</span>
            <span class="block text-xs text-gray-500 mt-0.5">
              Students join by code, or the student list may still change. Students form groups within
              the min/max limits — any leftover students will need lecturer intervention.
            </span>
          </div>
        </label>

        <%# Deterministic / student_list_finalised mode %>
        <label class="flex items-start gap-3 p-3 border rounded-md cursor-pointer hover:border-green-400 transition-colors
                      <%= @course.student_list_finalised? ? 'border-green-500 bg-green-50' : 'border-gray-200 bg-white' %>">
          <%= form.radio_button :student_list_finalised, true,
                class: "mt-0.5 focus:ring-green-500 h-4 w-4 text-green-600 border-gray-300 shrink-0",
                data: { action: "change->grouping-settings#toggleMode" } %>
          <div>
            <span class="block text-sm font-medium text-gray-800">Final student list</span>
            <span class="block text-xs text-gray-500 mt-0.5">
              I will import students and the student list is final — no new students will be added.
              The system can automatically determine legal group sizes for every student.
            </span>
          </div>
        </label>

      </div>
    </div>

    <%# ── Min / Max group size ────────────────────────────────────────────── %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :group_min, "Minimum group size",
              class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :group_min,
                min: 1,
                placeholder: "e.g. 3",
                class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                data: { grouping_settings_target: "minMax", action: "input->grouping-settings#clearPreview" } %>
        </div>
      </div>

      <div>
        <%= form.label :group_max, "Maximum group size",
              class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :group_max,
                min: 1,
                placeholder: "e.g. 4",
                class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                data: { grouping_settings_target: "minMax", action: "input->grouping-settings#clearPreview" } %>
        </div>
      </div>
    </div>

    <%# ── Preview section — shown only in student_list_finalised mode ──────── %>
    <div
      data-grouping-settings-target="previewSection"
      class="bg-gray-50 border border-gray-200 rounded-md p-4 space-y-3"
    >
      <div>
        <p class="text-sm font-medium text-gray-700">Preview group distribution</p>
        <p class="text-xs text-gray-500 mt-0.5">
          Enter an expected student count to see how legal groups would form.
          Actual numbers will come from enrolled students.
        </p>
      </div>

      <div class="flex items-center gap-3">
        <input
          type="number"
          id="grouping_preview_count"
          name="student_count"
          min="1"
          placeholder="e.g. 30"
          class="appearance-none w-36 px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
          hx-get="<%= grouping_preview_course_path(@course) %>"
          hx-include="[name='student_count'], [name='course[group_min]'], [name='course[group_max]']"
          hx-params="student_count,course[group_min],course[group_max]"
          hx-target="#grouping_preview_result"
          hx-trigger="input changed delay:400ms"
          data-grouping-settings-target="previewInput"
        >
        <span class="text-sm text-gray-500">students</span>
      </div>

      <%# HTMX renders into this div %>
      <div id="grouping_preview_result" class="text-sm">
        <%# populated by HTMX %>
      </div>
    </div>

    <%# ── Optional grouping window ─────────────────────────────────────────── %>
    <div>
      <div class="flex items-center justify-between mb-2">
        <span class="block text-sm font-medium text-gray-700">Grouping window (optional)</span>
        <button
          type="button"
          class="text-xs text-green-700 hover:underline"
          data-action="click->grouping-settings#toggleWindow"
          data-grouping-settings-target="windowToggleBtn"
        >
          <%= (@course.grouping_opens_at.present? || @course.grouping_closes_at.present?) ? 'Remove window' : 'Set a window' %>
        </button>
      </div>

      <p class="text-xs text-gray-500 mb-3">
        After the window closes, students lose access to grouping. Coordinators and lecturers
        always retain access.
      </p>

      <div
        data-grouping-settings-target="windowFields"
        class="grid grid-cols-1 md:grid-cols-2 gap-6"
      >
        <div>
          <%= form.label :grouping_opens_at, "Open from",
                class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.datetime_local_field :grouping_opens_at,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  value: @course.grouping_opens_at&.strftime('%Y-%m-%dT%H:%M') %>
          </div>
        </div>

        <div>
          <%= form.label :grouping_closes_at, "Close at",
                class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.datetime_local_field :grouping_closes_at,
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm",
                  value: @course.grouping_closes_at&.strftime('%Y-%m-%dT%H:%M') %>
          </div>
        </div>
      </div>
    </div>

  </div><%# /groupingOptions %>
</div><%# /data-controller %>
