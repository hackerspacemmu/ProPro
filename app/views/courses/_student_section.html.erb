<% container_classes =
  "border border-gray-200 shadow-xs rounded-[10px] w-full p-4 bg-[#f8f9fa] mb-5" %>

<section id="proposal-status">
  <div class="<%= container_classes %>">
    <%= render "project_status_bar",
    project: project,
    course: course,
    enrolment: current_user_enrolment %>
  </div>
</section>

<section id="supervisors-available">
  <div class="<%= container_classes %>">
    <header>
    <% unless @course.solo_supervisor? %>
      <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">Supervisors Available</h4>
    <% else %>
      <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">Instructor:</h4>
    <% end %>
    </header>
    <ul
      class="
        list-none p-0 mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5
      "
    >
      <%= render partial: "lecturers",
      collection: lecturers,
      as: :lecturer,
      locals: {
        course: course,
      } %>
    </ul>
  </div>
</section>

<% if @course.toggle_topics %>
  <section id="available-topics">
    <div class="<%= container_classes %>">
      <header>
        <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">Available Topics</h4>
        <p class="text-gray-500">Topics available for selection</p>

        <div class="flex flex-wrap items-center gap-2 mt-2">
            <%= link_to "View All Topics",
            course_topics_path(course),
            class: "inline-flex items-center px-3 py-1.5 text-xs font-semibold text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition-colors" %>
        </div>
      </header>

      <div class="flex flex-start gap-4 flex-wrap mt-2 pt-1 pb-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
          <% available_topics = policy_scope(@topic_list) %>
          <% if available_topics.any? %>
            <%= render partial: "topic_card", collection: available_topics, as: :topic %>
          <% else %>
            <p class="mt-1 col-span-full text-left">No topics are currently available.</p>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>
