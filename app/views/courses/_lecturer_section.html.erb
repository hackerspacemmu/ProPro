<% container_classes =
  "border border-gray-200 shadow-xs rounded-[10px] w-full p-4 bg-[#f8f9fa] mb-5" %>

<section id="my-student-projects">
  <div class="<%= container_classes %>">
    <header>
      <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">My Student Projects</h4>
      <p class="text-gray-500">Approved student projects currently under your supervision</p>
    </header>

    <div class="mt-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
        <% if my_student_projects.any? %>
          <%= render partial: "project_card", collection: my_student_projects, as: :project %>
        <% else %>
          <p class="col-span-full text-left text-gray-500">No approved student projects yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section id="incoming-proposals">
  <div class="<%= container_classes %>">
    <header>
      <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">Incoming Proposals</h4>
      <p class="text-gray-500">Student proposals awaiting approval</p>
    </header>
    <% if incoming_proposals.empty? %>
      <p class="mt-3 text-gray-500 break-word whitespace-pre-line">No student proposals are pending approval.</p>
    <% else %>
      <% %w[pending redo rejected].each do |stat| %>
        <% group = incoming_proposals.select { |p| p.status.to_s == stat } %>
        <% if group.any? %>
          <% is_collapsible = %w[redo rejected].include?(stat) %>
          <div class="mb-3 mt-2">
            <div class="flex items-center justify-start gap-2 pb-2 pt-2">
              <% if is_collapsible %>
                <button
                  type="button"
                  class="flex items-center justify-center w-7 h-7 rounded-md hover:bg-gray-200 transition-colors cursor-pointer"
                  onclick="
                    const grid = this.closest('.mb-3').querySelector('.grid');
                    const arrow = this.querySelector('.arrow');
                    grid.classList.toggle('hidden');
                    arrow.classList.toggle('rotate-90');"
                >
                  <%= image_tag "collapsable_arrow.svg", class: "arrow w-6 h-6 transition-transform duration-200" %>
                </button>
              <% end %>
              <div class="flex items-center gap-3">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md text-white <%= status_badge_classes(stat) %>">
                  <div class="bg-white rounded-full p-0.5 flex items-center justify-center">
                    <%= image_tag "#{stat}.svg", class: "inline-block w-4 h-4" %>
                  </div>
                  <span class="font-medium"><%= stat.upcase %></span>
                </div>
                <span class="text-sm text-gray-500"><%= group.size %></span>
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-6 w-full <%= 'hidden' if is_collapsible %>">
              <%= render partial: "project_card", collection: group, as: :project %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

<section id="supervisors-available">
  <div class="<%= container_classes %>">
    <header>
      <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">Supervisors Available</h4>
    </header>
    <ul
      class="
        list-none p-0 mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5
      "
    >
      <%= render partial: "lecturers",
      collection: lecturers,
      as: :lecturer,
      locals: {
        course: course,
      } %>
    </ul>
  </div>
</section>

<section id="my-topics">
  <div class="<%= container_classes %>">
    <header>
      <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">My Topics</h4>
      <div>
        <% if course.require_coordinator_approval? %>
          <p class="text-gray-500 mb-3">Draft topics here. Approved topics appear in your Lecturer View
            (visible to students)</p>
        <% else %>
          <p class="text-gray-500 mb-3">Your submitted topics. Only approved topics are visible to students
            in your Lecturer View.</p>
        <% end %>

        <div class="flex flex-wrap items-center gap-2 mt-2">
          <%= link_to "View All Topics",
          course_topics_path(course),
          class: "inline-flex items-center px-3 py-1.5 text-xs font-semibold text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition-colors" %>

          <% if policy(Topic.new(course: course)).create? %>
            <%= link_to "Create Topic",
            new_course_topic_path(course),
            class: "inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-indigo-500 hover:bg-indigo-600 rounded-lg transition-colors" %>
          <% end %>
        </div>
      </div>
    </header>

    <% if my_topics.empty? %>
      <p class="mt-3 col-span-full text-left text-gray-500">You haven't created any topics yet.</p>
    <% else %>
      <% %w[approved pending redo rejected].each do |stat| %>
        <% group = my_topics.select { |p| p.status.to_s == stat } %>
        <% if group.any? %>
          <% is_collapsible = stat != "approved" %>
          <div class="mb-3 mt-2">
            <div class="flex items-center justify-start gap-2 pb-2 pt-2">
              <% if is_collapsible %>
                <button
                  type="button"
                  class="flex items-center justify-center w-7 h-7 rounded-md hover:bg-gray-200 transition-colors cursor-pointer"
                  onclick="
                    const grid = this.closest('.mb-3').querySelector('.grid');
                    const arrow = this.querySelector('.arrow');
                    grid.classList.toggle('hidden');
                    arrow.classList.toggle('rotate-90');"
                >
                  <%= image_tag "collapsable_arrow.svg", class: "arrow w-6 h-6 transition-transform duration-200" %>
                </button>
              <% end %>
              <div class="flex items-center gap-3">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md text-white <%= status_badge_classes(stat) %>">
                  <div class="bg-white rounded-full p-0.5 flex items-center justify-center">
                    <%= image_tag "#{stat}.svg", class: "inline-block w-4 h-4" %>
                  </div>
                  <span class="font-medium"><%= stat.upcase %></span>
                </div>
                <span class="text-sm text-gray-500"><%= group.size %></span>
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full <%= 'hidden' if is_collapsible %>">
              <%= render partial: "topic_card", collection: group, as: :topic %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>
