<% container_classes =
  "border border-gray-200 shadow-xs rounded-[10px] w-full p-4 bg-[#f8f9fa] mb-5" %>
<section id="my-student-projects">
  <div class="<%= container_classes %>">
    <header>
      <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">My Student Projects</h4>
      <p class="text-gray-500">Student projects currently under supervision</p>
    </header>
    <div class="flex flex-start gap-4 flex-wrap mt-2 pt-1 pb-1">
      <div
        class="
          grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-6 w-full
        "
      >
        <% if my_student_projects.any? %>
          <%= render partial: "project_card",
          collection: my_student_projects,
          as: :project,
          locals: {
            course: @course,
          } %>
        <% else %>
          <p class="mt-1 col-span-full text-left">No approved student projects yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section id="incoming-proposals">
  <div class="<%= container_classes %>">
    <header>
      <h4
        class="
          text-xl text-black mb-3 font-normal break-word whitespace-pre-line
        "
      >Incoming Proposals</h4>
      <p class="text-gray-500">Student proposals awaiting approval</p>
    </header>
    <% if incoming_proposals.empty? %>
      <p class="mt-3 break-word whitespace-pre-line">No student proposals are pending approval.</p>
    <% else %>
      <% %w[pending redo rejected].each do |stat| %>
        <% group = incoming_proposals.select { |p| p.status.to_s == stat } %>
        <% if group.any? %>
          <% is_collapsible = %w[redo rejected].include?(stat) %>

          <div class="mb-3 mt-2">
            <div class="flex items-center justify-start gap-2 pb-2 pt-2 sm:pl-3">

              <button
                type="button"
                class="flex items-center justify-center w-7 h-7 rounded-md hover:bg-gray-200 transition-colors cursor-pointer"
                onclick="
                  const grid = this.closest('.mb-3').querySelector('.grid');
                  const arrow = this.querySelector('.arrow');
                  grid.classList.toggle('hidden');
                  arrow.classList.toggle('rotate-90');"
              >
                <% arrow_class = is_collapsible ? 'arrow w-6 h-6 transition-transform duration-200' : 'arrow w-6 h-6 transition-transform duration-200 rotate-90' %>
                <%= image_tag "collapsable_arrow.svg", class: arrow_class %>
              </button>

                <div class="flex items-center gap-3">
                  <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md text-white <%= status_badge_classes(stat) %>">
                    <div class="bg-white rounded-full p-0.5 flex items-center justify-center">
                      <%= image_tag "#{stat}.svg", class: "inline-block w-4 h-4" %>
                    </div>
                    <span class="font-medium"><%= stat.upcase %></span>
                  </div>
                  <span class="text-sm text-gray-500"><%= group.size %> </span>
                </div>

            </div>
            <%# Add the 'hidden' class conditionally if this group is collapsible, project card grid %>
            <div
              class="
                grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-6 w-full sm:pl-8
                <%= 'hidden' if is_collapsible %>
              "
            >
              <%= render partial: "project_card", collection: group, as: :project %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

<section id="my-topics">
  <div class="<%= container_classes %>">
  <header class="mb-3">
    <div class="flex items-center gap-3 flex-wrap">
      <h4 class="text-xl text-black font-normal break-word whitespace-pre-line">My Topics</h4>
      <div class="flex items-center gap-2 pl-5">
        <%= link_to "View All Topics",
        course_topics_path(course),
        class: "inline-flex items-center px-3 py-1.5 text-xs font-semibold text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors" %>
        <% if policy(Topic.new(course: course)).create? %>
          <%= link_to "Create Topic",
          new_course_topic_path(course),
          class: "inline-flex items-center px-3 py-1.5 text-xs font-semibold text-white bg-gray-600 hover:bg-gray-700 rounded-lg transition-colors" %>
        <% end %>
      </div>
    </div>
    <p class="text-gray-500 mt-1">Your submitted topics. Only approved topics are visible to students in your Lecturer View.</p>
  </header>
    
    <% if my_topics.empty? %>
      <p class="mt-3 col-span-full text-left">You haven't created any topics yet.</p>
    <% else %>
      <% %w[approved pending redo rejected].each do |stat| %>
        <% group = my_topics.select { |p| p.status.to_s == stat } %>

        <% if group.any? %>
          <% is_collapsible = stat != "approved" %>
          <div class="mb-3 mt-2">
            <div class="flex items-center justify-start gap-2 pb-2 pt-2 sm:pl-3">
              <button
                type="button"
                class="flex items-center justify-center w-7 h-7 rounded-md hover:bg-gray-200 transition-colors cursor-pointer"
                onclick="
                  const grid = this.closest('.mb-3').querySelector('.grid');
                  const arrow = this.querySelector('.arrow');
                  grid.classList.toggle('hidden');
                  arrow.classList.toggle('rotate-90');"
              >
                <% arrow_class = is_collapsible ? 'arrow w-6 h-6 transition-transform duration-200' : 'arrow w-6 h-6 transition-transform duration-200 rotate-90' %>
                <%= image_tag "collapsable_arrow.svg", class: arrow_class %>
              </button>

              <div class="flex items-center gap-3">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md text-white <%=  status_badge_classes(stat) %>">
                  <div class="bg-white rounded-full p-0.5 flex items-center justify-center">
                    <%= image_tag "#{stat}.svg", class: "inline-block w-4 h-4" %>
                  </div>
                  <span class="font-medium"><%= stat.upcase %></span>
                </div>
                <span class="text-sm text-gray-500"><%= group.size %></span>
              </div>

            </div>
            <div class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-6 w-full sm:pl-8 <%= 'hidden' if is_collapsible %>">
              <%= render partial: "topic_card", collection: group, as: :topic %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

<section id="supervisors-available">
  <div class="<%= container_classes %>">
    <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">Supervisors Available</h4>
    <ul
      class="
        list-none p-0 mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5
      "
    >
      <%= render partial: "lecturers",
      collection: lecturers,
      as: :lecturer,
      locals: {
        course: course,
      } %>
    </ul>
  </div>
</section>

<section id="incoming-topics">
  <div class="<%= container_classes %>">
    <header>
      <h4 class="text-xl text-black mb-3 font-normal break-word whitespace-pre-line">Incoming Topics</h4>
      <p class="text-gray-500 mb-3">Lecturer-proposed topics awaiting your approval</p>
    </header>
    <% incoming_topics =
      topic_list.select do |project|
        project.lecturer? && project.owner != current_user &&
          %w[pending redo rejected].include?(project.status.to_s)
      end %>
    <% if incoming_topics.empty? %>
      <p class="mt-1 col-span-full text-left">No Topics submmited to you.</p>
    <% else %>

      <% %w[pending redo rejected].each do |stat| %>
        <% group = incoming_topics.select { |p| p.status.to_s == stat } %>
        <% if group.any? %>
          <% is_collapsible = stat != "pending" %>

          <div class="mt-2 mb-3">
            <div class="flex items-center justify-start gap-2 pb-2 pt-2 sm:pl-3">

              <button
                type="button"
                class="flex items-center justify-center w-7 h-7 rounded-md hover:bg-gray-200 transition-colors cursor-pointer"
                onclick="
                  const grid = this.closest('.mt-2').querySelector('.grid');
                  const arrow = this.querySelector('.arrow');
                  grid.classList.toggle('hidden');
                  arrow.classList.toggle('rotate-90');"
              >
                <% arrow_class = is_collapsible ? 'arrow w-6 h-6 transition-transform duration-200' : 'arrow w-6 h-6 transition-transform duration-200 rotate-90' %>
                <%= image_tag "collapsable_arrow.svg", class: arrow_class %>
              </button>

              <div class="flex items-center gap-3">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md text-white <%=  status_badge_classes(stat) %>">
                  <div class="bg-white rounded-full p-0.5 flex items-center justify-center">
                    <%= image_tag "#{stat}.svg", class: "inline-block w-4 h-4" %>
                  </div>
                  <span class="font-medium"><%= stat.upcase %></span>
                </div>
                <span class="text-sm text-gray-500"><%= group.size %></span>
              </div>
            </div>

            <div 
              class="
              grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-6 w-full sm:pl-8
                <%= 'hidden' if is_collapsible %>
                "
            >
              <%= render partial: "topic_card", collection: group, as: :topic %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>