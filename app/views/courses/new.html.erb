<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "tailwind", "new_tailwind" %>
<% end %>
<% content_for :title, "Create Course | ProPro" %>

<div class="w-[95%] flex-1 bg-[#efefef] mx-auto py-6 px-4 flex flex-col">
  <h1 class="font-bold text-3xl text-black mb-6">Create Course</h1>

  <div>
    <% if flash[:alert] %>
      <div class="mb-4 p-4 text-red-700 bg-red-100 rounded-md border border-red-200">
        <%= flash[:alert] %>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div
        class="
          mb-4 p-4 text-green-700 bg-green-100 rounded-md border border-green-200
        "
      >
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%= form_with url: courses_path, model: @new_course, method: :post do |form| %>
      <% if @new_course.errors.any? %>
        <div id="error_explanation" class="mb-6 p-4 bg-red-50 rounded-md">
          <h2 class="text-sm font-semibold text-red-800">
            <%= pluralize(@new_course.errors.count, "error") %>
            prohibited this course from being saved:
          </h2>
          <ul class="mt-2 list-disc list-inside text-sm text-red-700">
            <% @new_course.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex flex-col gap-y-8 max-w-2xl">

        <div>
          <%= form.label :course_name,
                     "Course Name",
                     class: "block text-md font-medium text-gray-900" %>
          <div class="mt-2">
            <%= form.text_field :course_name,
                            id: "course_name",
                            required: true,
                            autofocus: true,
                            placeholder: "Enter Course Name",
                            class:
                              "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" %>
          </div>
        </div>

        <fieldset>
          <legend class="text-md font-medium text-gray-900">How will students work?</legend>
          <div class="mt-2 space-y-3">
            <div class="flex items-center gap-x-3">
              <%= form.radio_button :grouped,
                                "true",
                                required: true,
                                class:
                                  "h-4 w-4 border-gray-300 text-indigo-600 focus:ring-indigo-600" %>
              <%= form.label :grouped,
                         "In groups",
                         value: true,
                         class: "block text-sm/6 font-medium text-gray-900" %>
            </div>
            <div class="flex items-center gap-x-3">
              <%= form.radio_button :grouped,
                                "false",
                                required: true,
                                class:
                                  "h-4 w-4 border-gray-300 text-indigo-600 focus:ring-indigo-600" %>
              <%= form.label :grouped,
                         "By themselves",
                         value: false,
                         class: "block text-sm/6 font-medium text-gray-900" %>
            </div>
          </div>
        </fieldset>

        <div>
          <%= form.submit "Create Course",
                      class:
                        "cursor-pointer rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
