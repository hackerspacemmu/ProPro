<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "tailwind", "new_tailwind" %>
<% end %>

<% content_for :title,
"Add Lecturers - #{@course.course_name.truncate(TITLE_NAME_LIMIT)} | ProPro" %>
<% content_for :hide_toggler, true %>
<% breadcrumb :course_add_lecturers, @course %>

<main
  class="
    bg-gray-50 w-full pt-4 pb-8 px-4 sm:px-6 md:px-8 transition-all duration-300
  "
>

  <div class="mx-auto w-full max-w-xl md:max-w-2xl lg:max-w-4xl">

    <%= link_to course_path(@course), class: "group inline-flex items-center gap-3 text-sm font-medium text-gray-500 hover:text-green-600 transition-colors mb-6" do %>
      <div
        class="
          w-8 h-8 rounded-full bg-white border border-gray-200 flex items-center
          justify-center group-hover:border-green-300 shadow-sm transition-all
        "
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"
          /></svg>
      </div>
      Back to Course
    <% end %>
    <%# --- Flash Messages --- %>
    <% if flash[:alert] %>
      <div
        class="
          bg-red-50 text-red-700 p-4 rounded-xl mb-6 text-sm font-medium shadow-sm flex
          items-center gap-3
        "
      >
        <svg
          class="w-5 h-5 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          /></svg>
        <%= flash[:alert] %>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div
        class="
          bg-green-50 text-green-700 p-4 rounded-xl mb-6 text-sm font-medium shadow-sm
          flex items-center gap-3
        "
      >
        <svg
          class="w-5 h-5 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
          /></svg>
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%# --- Page Header --- %>
    <div class="mb-8 text-center sm:text-left">

      <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-2">
        Add Lecturers
      </h1>
      <h2 class="text-lg text-gray-500 font-medium">
        <%= @course.course_name %>
      </h2>
    </div>

    <%# --- Form Card --- %>
    <div
      class="
        bg-white rounded-xl sm:rounded-2xl shadow-sm border border-gray-100
        overflow-hidden
      "
    >

      <%# Instructions Banner %>
      <div class="bg-blue-50/50 border-b border-blue-100 p-6">
        <h3 class="text-sm font-bold text-blue-900 mb-1">Invitation Format</h3>
        <p class="text-sm text-blue-800/80 leading-relaxed">
          Enter the email addresses of the lecturers you wish to invite.
          Separate multiple email addresses using a semicolon.
        </p>
      </div>

      <div class="p-6 sm:p-8">
        <%= form_with url: handle_add_lecturers_course_path, method: :post, class: "space-y-6" do |form| %>

          <div class="flex flex-col gap-2">
            <%= form.label :invited_lecturers,
                       "Lecturer Email Addresses",
                       class:
                         "block text-sm font-bold text-gray-700 uppercase tracking-wide" %>

            <%= form.text_area :invited_lecturers,
                           required: true,
                           placeholder:
                             "e.g. lecturer1@university.edu; lecturer2@university.edu",
                           class:
                             "w-full px-4 py-3 border border-gray-200 rounded-xl text-gray-700 bg-gray-50 focus:outline-none focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all font-medium placeholder-gray-400 text-sm sm:text-base min-h-[120px] resize-y" %>
          </div>

          <div
            class="
              pt-4 flex flex-col sm:flex-row items-center justify-end gap-3 sm:gap-4
            "
          >
            <%= link_to "Cancel",
            course_path(@course),
            class:
              "w-full sm:w-auto text-center text-sm font-bold text-gray-500 hover:text-gray-800 px-6 py-3 rounded-xl hover:bg-gray-100 transition-colors" %>

            <%= form.submit "Send Invitations",
                        class:
                          "w-full sm:w-auto cursor-pointer bg-slate-600 hover:bg-slate-700 text-white font-bold py-3.5 px-8 rounded-xl shadow-lg shadow-slate-500/20 hover:shadow-slate-500/30 transition-all transform active:scale-95 text-sm sm:text-base flex justify-center items-center" %>
          </div>

        <% end %>
      </div>
    </div>

  </div>
</main>
