<section class="w-full scroll-mt-32" id="topic-fields">

  <%# --- Header --- %>
  <div class="border-b border-gray-200 mb-6">
    <nav
      class="-mb-px flex space-x-8 justify-center md:justify-start"
      aria-label="Tabs"
    >
      <span
        class="
          whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-bold
          text-gray-900 text-lg
        "
      >
        Topic Details
      </span>
    </nav>
  </div>

  <%# --- Main Fields Container --- %>
  <div
    class="
      bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-8
    "
  >
    <div class="flex flex-col divide-y divide-gray-100">

      <% fields.each do |field| %>
        <div
          class="
            flex flex-col sm:grid sm:grid-cols-[130px_1fr] md:grid-cols-3 group
            hover:bg-gray-50/50 transition-colors
          "
        >

          <%# Left Column: Field Label %>
          <div
            class="
              px-4 py-3 sm:p-4 md:p-6 sm:col-span-1 bg-gray-50/30 border-b sm:border-b-0
              sm:border-r border-gray-100 flex items-center sm:items-start
            "
          >
            <h3
              class="
                text-xs md:text-sm font-bold text-slate-600 uppercase tracking-wide
                leading-relaxed break-words
              "
            >
              <%= field.project_template_field.label %>
            </h3>
          </div>

          <%# Right Column: Field Value %>
          <%# Field value calculation (pre-calculated to prevent whitespace issues) %>
          <% display_text = nil
          if field.value.present?
            if field.project_template_field.dropdown? ||
                 field.project_template_field.radio?
              begin
                parsed = JSON.parse(field.value)
                display_text = parsed.is_a?(Array) ? parsed.join(", ") : parsed
              rescue JSON::ParserError
                display_text = field.value
              end
            else
              display_text = field.value
            end
            display_text = display_text.to_s.strip
          end %>

          <%# Field value container %>
          <div
            class="
              p-4 md:p-6 sm:col-span-1 md:col-span-2 text-gray-900 break-words text-base
              md:text-lg font-medium whitespace-pre-wrap leading-relaxed min-w-0
            "
          ><% if display_text.present? %><%= display_text %><% else %><span class="text-gray-400 italic font-normal text-base md:text-lg">No content provided</span><% end %></div>

        </div>
      <% end %>
      <% if is_student %>
        <%= link_to "Propose Based on this Topic", new_course_project_path(@course, topic_id: topic.id), 
        class: "inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white transition-all duration-200 bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 hover:shadow-md" %>
      <% end %>
    </div>
  </div>

  <%# ---DIFF TOOL--- %>
  <% if @index < @instances.size %>

    <div
      class="
        mt-8 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden
      "
    >
      <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
        <h4 class="text-base font-bold text-gray-800">Comparison with next instance</h4>
      </div>

      <div class="overflow-x-auto p-6">
        <table class="w-full text-sm text-left border-collapse border border-gray-200">
          <thead>
            <tr>
              <th
                class="
                  w-1/5 border border-gray-200 p-3 align-top bg-gray-50 text-left font-semibold
                  text-gray-700
                "
              >Field</th>
              <th
                class="
                  w-2/5 border border-gray-200 p-3 align-top text-red-700 bg-red-50/50
                  font-semibold
                "
              >Deletions</th>
              <th
                class="
                  w-2/5 border border-gray-200 p-3 align-top text-green-700 bg-green-50/50
                  font-semibold
                "
              >Additions</th>
            </tr>
          </thead>
          <tbody>
            <% fields.zip(next_fields).each do |current_field, next_field| %>
              <% field_name = (current_field || next_field).project_template_field.label %>

              <% normalize = ->(text) do
                text.to_s.gsub(/\r\n?/, "\n").gsub(/^$/, "[[EMPTYLINE]]")
              end %>

              <% old_val = normalize.call(current_field&.value) %>
              <% new_val = normalize.call(next_field&.value) %>

              <tr class="border border-gray-200">
                <td class="border border-gray-200 p-3 align-top font-medium text-gray-900"><%= field_name %></td>

                <% if old_val != new_val %>
                  <% old_lines = old_val.split("\n") %>
                  <% new_lines = new_val.split("\n") %>

                  <%# Use Diff::LCS to align line changes properly %>
                  <% diffs = Diff::LCS.sdiff(old_lines, new_lines) %>

                  <% aligned_left = [] %>
                  <% aligned_right = [] %>

                  <%# Base Tailwind classes for all diff list items to keep strings clean %>
                  <% base_li = "list-none border border-dashed border-black/10 mb-[2px] min-h-[1em]" %>

                  <% diffs.each do |change| %>
                    <% case change.action %>
                    <% when '=' %>
                      <% line = h(change.old_element) %>
                      <% aligned_left << "<li class='#{base_li}'>#{line}</li>" %>
                      <% aligned_right << "<li class='#{base_li}'>#{line}</li>" %>

                    <% when '-' %>
                      <% line = change.old_element.to_s %>
                      <% if line.strip.empty? || line == "[[EMPTYLINE]]" %>
                        <% aligned_left << "<li class='#{base_li} bg-[#f4d4d4]'><span class='bg-[#FF6961] line-through'><br></span></li>" %>
                        <% aligned_right << "<li class='#{base_li} bg-gray-100 text-transparent select-none'><br></li>" %>
                      <% else %>
                        <% safe_line = h(change.old_element) %>
                        <% aligned_left << "<li class='#{base_li} bg-[#f4d4d4]'><span class='bg-[#FF6961] line-through'>#{safe_line}</span></li>" %>
                        <% aligned_right << "<li class='#{base_li} bg-gray-100 text-transparent select-none'>#{safe_line}</li>" %>
                      <% end %>

                    <% when '+' %>
                      <% line = change.new_element.to_s %>
                      <% if line.strip.empty? || line == "[[EMPTYLINE]]" %>
                        <% aligned_left << "<li class='#{base_li} bg-gray-100 text-transparent select-none'><br></li>" %>
                        <% aligned_right << "<li class='#{base_li} bg-[#d4f4dd]'><span class='bg-[#77DD77]'><br></span></li>" %>
                      <% else %>
                        <% safe_line = h(change.new_element) %>
                        <% aligned_left << "<li class='#{base_li} bg-gray-100 text-transparent select-none'>#{safe_line}</li>" %>
                        <% aligned_right << "<li class='#{base_li} bg-[#d4f4dd]'><span class='bg-[#77DD77]'>#{safe_line}</span></li>" %>
                      <% end %>

                    <% when '!' %>
                      <% old_line = change.old_element.to_s %>
                      <% new_line = change.new_element.to_s %>

                      <%# Do word-level diff inside this line %>
                      <% old_words = old_line.split(/(\s+)/) %>
                      <% new_words = new_line.split(/(\s+)/) %>
                      <% word_diffs = Diff::LCS.sdiff(old_words, new_words) %>

                      <% old_html =
                        word_diffs
                          .map do |w|
                            case w.action
                            when "="
                              h(w.old_element)
                            when "-", "!"
                              "<span class='bg-[#FF6961] line-through'>#{h(w.old_element)}</span>"
                            else
                              ""
                            end
                          end
                          .join %>

                      <% new_html =
                        word_diffs
                          .map do |w|
                            case w.action
                            when "="
                              h(w.new_element)
                            when "+", "!"
                              "<span class='bg-[#77DD77]'>#{h(w.new_element)}</span>"
                            else
                              ""
                            end
                          end
                          .join %>

                      <% aligned_left << "<li class='#{base_li} bg-[#f4d4d4]'>#{old_html}</li>" %>
                      <% aligned_right << "<li class='#{base_li} bg-[#d4f4dd]'>#{new_html}</li>" %>
                    <% end %>
                  <% end %>

                  <td class="w-1/2 break-words align-top border border-gray-200 p-3">
                    <ul class="list-none p-0 m-0 font-mono text-xs">
                      <%= aligned_left.join.gsub("[[EMPTYLINE]]", "<br>").html_safe %>
                    </ul>
                  </td>

                  <td class="w-1/2 break-words align-top border border-gray-200 p-3">
                    <ul class="list-none p-0 m-0 font-mono text-xs">
                      <%= aligned_right.join.gsub("[[EMPTYLINE]]", "<br>").html_safe %>
                    </ul>
                  </td>

                <% else %>
                  <td
                    colspan="2"
                    class="
                      border border-gray-200 p-3 align-top text-center text-gray-500 italic bg-gray-50
                    "
                  >No changes</td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

</section>
