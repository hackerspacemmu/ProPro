<% is_member = members.include?(current_user)
is_history = current_version != latest_version
has_actions = is_member || is_history %>

<section class="w-full">
  <div class="flex flex-col gap-4">

    <%# --- LECTURER ACTIONS --- %>
    <% if is_member %>
      <%# Edit Logic %>
      <% if (topic.status != "approved" && !is_history) || (!course.require_coordinator_approval) %>
        <div class="w-full">
          <% if !is_history %>
            <p
              class="
                text-xs font-bold text-green-600 uppercase tracking-wide mb-2 flex items-center
                gap-1
              "
            >
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
              Latest Version
            </p>
          <% end %>

          <%= link_to edit_course_topic_path(course, topic),
              class: "flex items-center justify-center w-full gap-2 bg-gray-900 hover:bg-gray-800 text-white font-bold py-2.5 px-4 rounded-xl transition-all shadow-sm active:scale-[0.98]" do %>
            <%= image_tag "edit_white.svg", class: "w-4 h-4" %>
            <span>Edit Topic</span>
          <% end %>
        </div>

      <% else %>
        <div
          class="
            w-full p-3 bg-gray-50 border border-gray-200 rounded-xl flex items-center
            justify-center gap-2 text-gray-400 select-none
          "
        >
          <%= image_tag "lock.svg", class: "w-4 h-4 opacity-50 grayscale" %>
          <span class="text-sm font-medium">Unable to Edit Topic</span>
        </div>
      <% end %>

      <%# Delete Logic %>
      <% if !is_history %>
        <%= button_to course_topic_path(course, topic),
            method: :delete,
            form: { data: { turbo_confirm: "Are you sure you want to delete this topic?" } },
            class: "flex items-center justify-center w-full gap-2 bg-white border border-red-200 text-red-600 hover:bg-red-50 hover:border-red-300 font-bold py-2.5 px-4 rounded-xl transition-colors shadow-sm active:scale-[0.98]" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
            /></svg>
          <span>Delete Topic</span>
        <% end %>
      <% end %>
    <% end %>

    <%# --- VERSION JUMP ACTION --- %>
    <% if is_history %>
      <%= link_to course_topic_path(course, topic),
          class: "flex items-center justify-center w-full gap-2 bg-white border-2 border-indigo-100 text-indigo-600 hover:bg-indigo-50 hover:border-indigo-200 font-bold py-2.5 px-4 rounded-xl transition-colors group" do %>
        <div
          class="
            w-5 h-5 rounded-full bg-indigo-100 flex items-center justify-center
            group-hover:bg-white transition-colors
          "
        >
          <%= image_tag "jump_version.svg", class: "w-3 h-3" %>
        </div>
        <span class="text-sm">Jump To Latest Version</span>
      <% end %>
    <% end %>

  </div>
</section>
