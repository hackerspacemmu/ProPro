<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "tailwind", "new_tailwind" %>
<% end %>

<% content_for :hide_toggler, true %>

<% breadcrumb :topic, @topic %>

<% content_for :title do %>
  <%= @topic.current_title.truncate(TITLE_NAME_LIMIT) %>
  - View Topic | ProPro
<% end %>

<main class="bg-gray-50 w-full pt-[1em] pb-6">

  <div class="max-w-[1920px] mx-auto w-full px-4 md:px-12 xl:px-16">

    <%# --- Flash Messages --- %>
    <% if flash[:alert] %>
      <div class="bg-red-50 text-red-700 p-4 rounded-lg mb-4 text-sm font-medium"><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="bg-green-50 text-green-700 p-4 rounded-lg mb-4 text-sm font-medium"><%= flash[:notice] %></div>
    <% end %>

    <%# --- Top Back Button --- %>
    <div class="flex items-center justify-start mb-2">
      <%= link_to course_path(@course), class: "group flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-green-600 transition-colors" do %>
        <div
          class="
            w-8 h-8 rounded-full bg-white border border-gray-200 flex items-center
            justify-center group-hover:border-green-300 shadow-sm transition-all
          "
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            /></svg>
        </div>
        Back to Course
      <% end %>
    </div>

    <%# --- Main Two-Column Layout --- %>
    <div
      class="
        flex flex-col xl:flex-row gap-0 md:gap-4 lg:gap-8 items-start justify-center
      "
    >

      <%# --- LEFT COLUMN: Content --- %>
      <div class="flex-1 w-full min-w-0 space-y-8">

        <% current_version = @index %>
        <% oldest_version = 1 %>
        <% latest_version = @instances.size %>

        <%= render "topic_header",
        current_instance: @current_instance,
        owner: @owner,
        topic: @topic,
        members: @members,
        current_version: current_version,
        latest_version: latest_version,
        oldest_version: oldest_version,
        is_student: @is_student,
        course: @course,
        index: @index,
        instances: @instances %>

        <section>
          <div>
            <%= render "topic_fields",
            fields: @fields,
            next_fields: @next_fields,
            topic: @topic,
            course: @course,
            index: @index,
            instances: @instances,
            is_student: @is_student %>
          </div>
        </section>

      </div>

      <%# --- RIGHT COLUMN: Actions & Comments --- %>
      <div class="w-full xl:w-[450px] flex-shrink-0 space-y-6">

        <div class="space-y-6 flex flex-col gap-6">

          <div class="flex flex-col md:flex-row xl:flex-col gap-6">

            <% has_actions =
              @members.include?(current_user) || current_version != latest_version %>

            <% if has_actions %>
              <section
                class="
                  bg-white rounded-2xl shadow-sm border border-gray-100 p-5 flex-1
                "
              >
                <h4
                  class="
                    text-xs font-bold text-gray-400 uppercase tracking-wider mb-4 flex items-center
                    gap-2
                  "
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 10V3L4 14h7v7l9-11h-7z"
                    /></svg>
                  Actions
                </h4>

                <%= render "topic_actions",
                members: @members,
                current_user: current_user,
                topic: @topic,
                current_version: current_version,
                latest_version: latest_version,
                course: @course %>
              </section>
            <% end %>

          </div>

          <%# --- Comments Section --- %>
          <section
            class="
              bg-white rounded-2xl shadow-sm border border-gray-100 flex flex-col h-[600px]
              max-h-[calc(100vh-200px)]
            "
          >
            <div class="flex-grow overflow-y-auto p-0 bg-gray-50/30 custom-scrollbar">
              <%= render "topic_comments",
              comments: @comments,
              new_comment: @new_comment,
              course: @course,
              topic: @topic,
              current_instance_id: @current_instance.id,
              current_version: current_version,
              latest_version: latest_version %>
            </div>
          </section>

        </div>
      </div>

    </div>

    <%# --- Bottom Back Button --- %>
    <div class="flex items-center justify-center pt-4 mb-2">
      <%= link_to course_path(@course), class: "group flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-green-600 transition-colors" do %>
        <div
          class="
            w-8 h-8 rounded-full bg-white border border-gray-200 flex items-center
            justify-center group-hover:border-green-300 shadow-sm transition-all
          "
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            /></svg>
        </div>
        Back to Course
      <% end %>
    </div>

  </div>
</main>
