<header
  class="
    w-full bg-gray-50 rounded-xl flex flex-col items-center gap-6 px-4 sm:px-8 py-6
  "
>

  <% if flash[:notice] %>
    <div
      data-testid="flash-notice"
      class="
        w-full p-4 rounded-xl bg-green-50 border border-green-200 text-green-700 text-sm
        font-bold flex items-center justify-center gap-3 shadow-sm -mb-2
      "
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 13l4 4L19 7"
        /></svg>
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div
      data-testid="flash-alert"
      class="
        w-full p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm
        font-bold flex items-center justify-center gap-3 shadow-sm -mb-2
      "
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
        /></svg>
      <%= flash[:alert] %>
    </div>
  <% end %>
  <h1
    class="
      text-3xl md:text-4xl font-bold text-gray-900 mb-2 mt-2 w-full break-words
      text-center md:text-left
    "
  >
    <%= current_instance.title %>
  </h1>

  <div
    class="
      w-full flex flex-col md:flex-row justify-between gap-8 lg:gap-12 min-w-0
    "
  >

    <%# --- LEFT COLUMN: Properties --- %>
    <div class="flex flex-col gap-6 min-w-0">

      <%# Type %>
      <div class="flex flex-row items-start gap-3 min-w-0">
        <span
          class="
            text-gray-700 font-semibold text-base flex items-center gap-2 min-w-[100px]
            sm:min-w-[120px] md:min-w-[140px] shrink-0
          "
        >
          <%= image_tag("person.svg", class: "w-4 h-4 object-contain opacity-70 shrink-0") %>
          Type
        </span>
        <span class="text-gray-900 break-words">
          <p>Topic</p>
        </span>
      </div>

      <%# Owner %>
      <div class="flex flex-row items-start gap-3 min-w-0">
        <span
          class="
            text-gray-700 font-semibold text-base flex items-center gap-2 min-w-[100px]
            sm:min-w-[120px] md:min-w-[140px] shrink-0
          "
        >
          <%= image_tag("person.svg", class: "w-4 h-4 object-contain opacity-70 shrink-0") %>
          Owner
        </span>
        <div class="flex flex-col gap-2 items-start text-gray-900 min-w-0">
          <% if owner.is_a?(User) %>
            <p class="flex items-center gap-2 break-words w-full">
              <span
                class="
                  inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-400
                  text-white text-xs font-bold uppercase shrink-0
                "
              >
                <%= owner.username[0].upcase %>
              </span>
              <span class="break-words"><%= owner.username %></span>
            </p>
          <% else %>
            <% topic.owner.users.each do |user| %>
              <p class="flex items-center gap-2 break-words w-full">
                <span
                  class="
                    inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-400
                    text-white text-xs font-bold uppercase shrink-0
                  "
                >
                  <%= user.username[0].upcase %>
                </span>
                <span class="break-words"><%= user.username %></span>
              </p>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Group Name (If Applicable) %>
      <% if topic.owner.is_a?(ProjectGroup) %>
        <div class="flex flex-row items-start gap-3 min-w-0">
          <span
            class="
              text-gray-700 font-semibold text-base flex items-center gap-2 min-w-[100px]
              sm:min-w-[120px] md:min-w-[140px] shrink-0
            "
          >
            <%= image_tag("group.svg", class: "w-4 h-4 object-contain opacity-70 shrink-0") %>
            Group Name
          </span>
          <span class="text-gray-900 break-words min-w-0">
            <%= topic.owner.group_name %>
          </span>
        </div>
      <% end %>

    </div>

    <%# --- RIGHT COLUMN: Status & Version Cards --- %>
    <div class="flex flex-col gap-6 w-full md:w-auto md:min-w-[280px] min-w-0">

      <%# STATUS CARD %>
      <div
        class="
          bg-white/80 backdrop-blur-sm rounded-xl p-3 flex flex-col gap-3 shadow-sm border
          border-white/50 min-w-0
        "
      >

        <div class="flex flex-row items-center justify-between gap-2 min-w-0">
          <span
            class="
              text-gray-700 font-semibold text-base flex items-center gap-2 shrink-0
            "
          >
            <%= image_tag("status.svg", class: "w-4 h-4 object-contain opacity-70 shrink-0") %>
            Status
          </span>

          <div class="flex-1 flex justify-end min-w-0 ml-2">
            <% if @is_coordinator && @course.require_coordinator_approval && current_version == latest_version %>
              <div class="flex items-center gap-1 sm:gap-2 min-w-0 justify-end">
                <%= form_with url: change_status_course_topic_path(@course, topic), method: :patch, local: true, class: "flex items-center gap-1 sm:gap-2 min-w-0 justify-end" do |f| %>
                  <% statuses = TopicInstance.statuses.keys.without("not_submitted") %>
                  <% status_color_class =
                    case current_instance.status
                    when "approved"
                      "bg-emerald-100 text-emerald-800 border-emerald-200"
                    when "rejected"
                      "bg-red-100 text-red-800 border-red-200"
                    when "redo"
                      "bg-orange-100 text-orange-800 border-orange-200"
                    else
                      "bg-gray-100 text-gray-800 border-gray-200"
                    end %>

                  <%= f.select :status,
                           options_for_select(
                             statuses.map { |s| [s.humanize, s] },
                             current_instance.status,
                           ),
                           {},
                           data: { testid: "status-select" },
                           class:
                             "min-w-0 w-auto px-2 py-1 text-sm border rounded-md focus:ring-2 focus:ring-blue-500 focus:outline-none truncate " +
                               "max-[324px]:max-w-[80px] " + status_color_class %>

                  <%= f.button type: "submit", data: { testid: "change-status-submit" }, class: "shrink-0 cursor-pointer hover:scale-110 transition-transform p-1", title: "Save status" do %>
                    <%= image_tag("check.svg", class: "w-4 h-4 shrink-0") %>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <%# Static Status Badge %>
              <% badge_color =
                case current_instance.status
                when "approved"
                  "bg-emerald-600"
                when "rejected"
                  "bg-red-600"
                when "redo"
                  "bg-orange-500"
                else
                  "bg-gray-500"
                end %>
              <span
                class="
                  px-3 py-1 rounded-md text-white text-sm font-medium capitalize
                  <%= badge_color %> truncate shrink-0
                "
              >
                <%= current_instance.status.humanize %>
              </span>
            <% end %>
          </div>
        </div>

        <%# Status Change Metadata %>
        <div
          class="
            text-xs text-gray-500 font-medium flex flex-col gap-1 border-t
            border-gray-200/50 pt-2 mt-1 min-w-0
          "
        >
          <% if current_instance.last_status_change_time.present? %>
            <div class="opacity-90 truncate"><%= format_timestamp(current_instance.last_status_change_time) || "-" %></div>
          <% end %>

          <div class="flex items-center gap-2 min-w-0">
            <% if current_instance.last_status_change_by.present? %>
              <% dot_color =
                case current_instance.status
                when "approved"
                  "bg-emerald-600"
                when "rejected"
                  "bg-red-600"
                when "redo"
                  "bg-orange-500"
                else
                  "bg-gray-400"
                end %>
              <span class="w-2.5 h-2.5 rounded-full <%= dot_color %> shrink-0"></span>
              <span class="truncate"><%= username(current_instance.last_status_change_by) || "Not changed" %></span>
            <% else %>
              <div class="flex items-center gap-1 truncate">
                <%= image_tag("pending.svg", class: "w-4 h-4 opacity-50 shrink-0") %>
                <span class="truncate">Awaiting review</span>
              </div>
            <% end %>
          </div>
        </div>

      </div>

      <%# VERSION CARD %>
      <div
        class="
          bg-white/80 backdrop-blur-sm rounded-xl p-3 flex flex-col gap-3 shadow-sm border
          border-white/50 min-w-0
        "
      >

        <div class="flex flex-row items-center justify-between gap-3 min-w-0">
          <span
            class="
              text-gray-700 font-semibold text-base flex items-center gap-2 shrink-0
            "
          >
            <%= image_tag("version.svg", class: "w-4 h-4 object-contain opacity-70 shrink-0") %>
            Version
            <% if current_version != latest_version %>
              <em class="text-xs text-gray-400 font-normal not-italic">(older)</em>
            <% end %>
          </span>

          <div class="flex items-center gap-2 sm:gap-3 shrink-0">
            <%# Back arrow %>
            <% if current_version > 1 %>
              <%= link_to course_topic_path(@course, topic, version: current_version - 1),
                data: { testid: "version-back" }, 
                class: "hover:bg-gray-100 rounded-full p-1 transition-colors" do %>
                <%= image_tag("arrow_back.svg", class: "w-3 h-3 shrink-0") %>
              <% end %>
            <% else %>
              <span class="opacity-30 p-1 cursor-not-allowed">
                <%= image_tag("arrow_back.svg", class: "w-3 h-3 shrink-0") %>
              </span>
            <% end %>

            <span data-testid="current-version" class="text-sm font-bold text-gray-800 whitespace-nowrap">
              <%= current_version %> of <%= instances.size %>
            </span>

            <%# Next arrow %>
            <% if current_version < instances.size %>
              <%= link_to course_topic_path(@course, topic, version: current_version + 1), 
                data: { testid: "version-next" },
                class: "hover:bg-gray-100 rounded-full p-1 transition-colors" do %>
                <%= image_tag("arrow_forward.svg", class: "w-3 h-3 shrink-0") %>
              <% end %>
            <% else %>
              <span class="opacity-30 p-1 cursor-not-allowed">
                <%= image_tag("arrow_forward.svg", class: "w-3 h-3 shrink-0") %>
              </span>
            <% end %>
          </div>
        </div>

        <%# Edit Metadata %>
        <div
          class="
            text-xs text-gray-500 font-medium flex flex-col gap-1 border-t
            border-gray-200/50 pt-2 mt-1 min-w-0
          "
        >
          <% if current_instance.last_edit_time.present? %>
            <div class="opacity-90 truncate"><%= format_timestamp(current_instance.last_edit_time) || "-" %></div>
          <% end %>

          <div class="flex items-center gap-2 min-w-0">
            <% editor_id = current_instance.last_edit_by || current_instance.created_by_id %>
            <%= image_tag("edit.svg", class: "w-4 h-4 opacity-50 shrink-0") %>
            <span class="truncate"><%= username(editor_id) || "Not changed" %></span>
          </div>
        </div>

      </div>

    </div>
  </div>
</header>
