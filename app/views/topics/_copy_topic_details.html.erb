<%= turbo_frame_tag "overlay_content", class: "flex flex-col h-full" do %>
  <%= form_with url: import_details_course_path(target), method: :post, class: "flex flex-col h-full max-h-[75vh]" do |f| %>
    <%= f.hidden_field :source_topic_id, value: source.id %>

    <div class="flex-none mb-6 flex items-center justify-between">
      <h3 class="text-2xl font-bold text-gray-600">Duplicate "<%= source.current_title %>" to:</h3>
      <button type="button" 
              data-action="click->overlay#goBack" 
              class="text-sm text-blue-600 hover:underline">
        ← Back
      </button>
    </div><br>

    <div class="flex-grow overflow-y-auto pr-2 scrollbar-thin">
      <ul class="divide-y divide-gray-100">
        <% current_instance = source.topic_instances.order(version: :desc).first %>
        <% fields = current_instance.project_instance_fields.includes(:project_template_field) %>

        <% @template_fields.each do |field| %>
          <li class="field-row py-5 flex items-start gap-6 border-b border-gray-100 last:border-0">
            <% initial_field = fields.find { |f| f.project_template_field.label == field.label } %>
            <% matched_found = initial_field.present? %>

            <div class="flex flex-col w-full gap-4">
              <div class="flex items-center gap-2"> 
                <span class="block text-xl font-bold text-gray-900 tracking-tight">
                  <%= field.label %>
                </span>
                
                <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-[11px] font-medium text-indigo-600 ring-1 ring-inset ring-indigo-200">
                  <%= field.field_type.humanize %>
                </span>
              </div>

              <div class="flex flex-col w-full">
                <select name="template_field[<%= field.id %>][instance_field_id]" 
                        data-action="change->overlay#updateDropdown"
                        class="block w-full rounded-t-lg border border-gray-100 bg-gray-50 px-4 py-4 pr-10 text-base transition-all focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-indigo-500"
                >
                  <option value="">-- Select a value --</option>
                  <% fields.each do |instance_field| %>
                    <option value="<%= instance_field.id %>"
                            data-label="<%= instance_field.project_template_field.label %>"
                            data-value="<%= instance_field.value %>"
                            <%= "selected" if instance_field == initial_field %>>
                      <%= instance_field.project_template_field.label %>
                    </option>
                  <% end %>
                </select>

                <div data-overlay-target="preview" class="<%= 'hidden' unless matched_found %> w-full border-x border-b border-gray-100 bg-white px-5 pt-3 pb-5 rounded-b-lg">
                  <p data-overlay-target="value" class="text-gray-600 text-sm leading-relaxed">
                    <%= initial_field&.value if matched_found %>
                  </p>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="flex-none mt-6 pt-4 flex justify-end">
      <%= f.submit "Copy Details", class: "px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 text-sm font-medium rounded shadow-sm transition" %>
    </div>
  <% end %>
<% end %>
