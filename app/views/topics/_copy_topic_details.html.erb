<%= turbo_frame_tag "overlay_content", class: "flex flex-col h-full" do %>
  <%= form_with url: import_details_course_path(target), method: :post, class: "flex flex-col h-full max-h-[75vh]" do |f| %> 
    <%= f.hidden_field :source_topic_id, value: source.id, id: "overlay_source_topic_id" %>

    <div class="flex-none mb-6 flex items-start justify-between gap-6">
      <h3 class="text-lg md:text-xl font-bold text-gray-700 leading-snug break-words max-w-[85%]">
        Copying from <span class="text-indigo-600">"<%= source.current_title %>"</span>
        <span class="block mt-0.5 md:mt-1 text-base md:text-lg font-medium text-gray-500">
          to new topic in <span class="font-bold text-green-700">"<%= target.course_name %>"</span>
        </span>
      </h3>
      <button type="button" 
              data-action="click->overlay#returnToList" 
              class="text-sm font-semibold text-blue-600 hover:text-blue-800 whitespace-nowrap mt-1 transition-colors">
        ← Back
      </button>
    </div>

    <div class="flex-grow overflow-y-auto pr-2 scrollbar-thin">
      <ul class="divide-y divide-gray-100">
        <% current_instance = source.topic_instances.order(version: :desc).first %>
        <% fields = current_instance.project_instance_fields.includes(:project_template_field) %>

        <% @template_fields.each do |field| %>
          <li class="field-row py-5 flex items-start gap-6 border-b border-gray-100 last:border-0">
            <% 
              initial_field = fields.find { |f| f.project_template_field.label == field.label } 
              show_preview = false

              if initial_field.present?
                source_value = initial_field.value.to_s.strip
                if ["dropdown", "radio"].include?(field.field_type.downcase)
                  allowed_options = (field.options || []).map { |opt| opt.to_s.strip }
                  show_preview = source_value.blank? || allowed_options.include?(source_value)
                else
                  show_preview = true
                end
              end
            %>

            <div class="flex flex-col w-full gap-3">
              <div class="flex items-center gap-2"> 
                <span class="block text-sm font-bold text-gray-800 uppercase tracking-wide">
                  <%= field.label %>
                </span>
                
                <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-[10px] font-bold text-indigo-600 uppercase tracking-wider ring-1 ring-inset ring-indigo-200">
                  <%= field.field_type_label %>
                </span>
              </div>

              <div class="flex flex-col sm:flex-row sm:items-start gap-2 w-full">
                <% 
                  valid_options = fields.select do |instance_field|
                    opt_value = instance_field.value.to_s.strip
                    if ["dropdown", "radio"].include?(field.field_type.downcase)
                      allowed_options = (field.options || []).map { |opt| opt.to_s.strip }
                      opt_value.blank? || allowed_options.include?(opt_value)
                    else
                      true
                    end
                  end
                %>
                <span class="text-xs font-bold text-gray-400 uppercase tracking-wider whitespace-nowrap sm:w-24 pt-3">
                  Copy from:
                </span>
                
                <div class="flex flex-col flex-grow w-full gap-3">
                  <div class="relative w-full">
                    <select name="template_field[<%= field.id %>][instance_field_id]" 
                            data-action="change->overlay#updateDropdown"
                            data-target-field-id="fields_<%= field.id %>"
                            class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 pr-10 text-sm font-medium text-gray-700 transition-all focus:border-indigo-500 focus:outline-none focus:ring-4 focus:ring-indigo-500/10 cursor-pointer shadow-sm hover:border-gray-400 appearance-none"
                    >
                      <option value="">
                        <%= (valid_options.empty? && ["dropdown", "radio"].include?(field.field_type.downcase)) ? "-- No Valid Option --" : "-- Do Not Copy / Leave Blank --" %>
                      </option>

                      <% fields.each do |instance_field| %>
                        <% 
                          opt_value = instance_field.value.to_s.strip
                          is_valid_choice = true

                          if ["dropdown", "radio"].include?(field.field_type.downcase)
                            allowed_options = (field.options || []).map { |opt| opt.to_s.strip }
                            is_valid_choice = opt_value.blank? || allowed_options.include?(opt_value)
                          end
                        %>

                        <% if is_valid_choice %>
                          <option value="<%= instance_field.id %>"
                                  data-label="<%= instance_field.project_template_field.label %>"
                                  data-value="<%= instance_field.value %>" 
                                  <%= "selected" if instance_field == initial_field %>>
                            <%= instance_field.project_template_field.label %>
                          </option>
                        <% end %>
                      <% end %>
                    </select>
                    
                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-400">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </div>
                  </div>

                  <div data-overlay-target="preview" class="<%= 'hidden' unless show_preview %> w-full border border-gray-200 bg-gray-50 px-5 py-4 rounded-lg shadow-inner">
                    <span class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Preview Content</span>
                    <p data-overlay-target="value" class="text-gray-700 text-sm leading-relaxed font-medium">
                      <%= initial_field&.value if show_preview %>
                    </p>
                  </div>

                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="flex-none mt-6 pt-4 border-t border-gray-100 flex justify-end">
      <button type="button" data-action="click->overlay#copyTopicsDetails" 
              class="px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 text-sm font-medium rounded shadow-sm transition">
        Copy Details
      </button>
    </div>
  <% end %>
<% end %>
