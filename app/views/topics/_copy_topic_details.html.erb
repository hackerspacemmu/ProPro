<%= turbo_frame_tag "overlay_content" do %>
  <%= form_with url: import_details_course_path(target), method: :post do |f| %>
    <%= f.hidden_field :source_topic_id, value: source.id %>

    <div class="flex items-center justify-between mb-6">
      <h3 class="text-2xl font-bold text-gray-600">Duplicate "<%= source.current_title %>" to:</h3>
      <%= link_to "← Back", new_course_topic_path(@course), class: "text-sm text-blue-600 hover:underline" %>
    </div><br>

    <div class="flex-grow max-h-[60vh] overflow-y-auto pr-2 scrollbar-thin">
      <ul class="divide-y divide-gray-100">
        <% current_instance = source.topic_instances.order(version: :desc).first %>
        <% fields = current_instance.project_instance_fields.includes(:project_template_field) %>

        <% @template_fields.each do |field| %>
          <li class="py-5 flex items-start gap-6 border-b border-gray-100 last:border-0">
            <div class="flex flex-col flex-grow">
              <div class="flex items-center gap-3 mb-2">
                <span class="block text-lg font-semibold text-gray-800">
                  <%= field.label %>
                </span>
                <span class="inline-flex items-center rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                  <%= field.field_type.humanize %>
                </span>
              </div>

              <div class="flex items-center gap-3 mb-2">
                <label for="instance_field_select_<%= field.id %>" class="sr-only">Select Instance Field</label>
                <select id="instance_field_select_<%= field.id %>" name="template_field[<%= field.id %>][instance_field_id]"
                    class="block w-full rounded-lg border border-gray-100 bg-gray-50/50 px-4 py-4 pr-10 text-slate-500 transition-all focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm"
                >
                  <option value="">-- Select a value --</option>
                  <% fields.each do |instance_field| %>
                    <% template_field = instance_field.project_template_field %>
                    <option value="<%= instance_field.id %>"><%= template_field.label %></option>
                  <% end %>
                </select>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
<% end %>
