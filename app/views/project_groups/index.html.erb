<%# app/views/project_groups/index.html.erb %>
<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "tailwind", "new_tailwind" %>
<% end %>

<%# --- Disables footer --- %>
<% content_for :no_footer, true %>
<% breadcrumb :course, @course %>

<div class="w-full max-w-[75rem] mx-auto px-6 py-4 space-y-5"
     data-controller="add-member-popup"
     data-course-id="<%= @course.id %>">

  <%# ── Add-member modals (coordinator only) — inside controller so targets are reachable %>
  <% if @current_user_enrolment&.coordinator? %>
    <%# Main modal %>
    <div data-add-member-popup-target="overlay"
         data-action="click->add-member-popup#closeOnBackdrop"
         class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center"
         role="dialog" aria-modal="true" aria-labelledby="add-member-modal-title">
      <div class="bg-white rounded-[4px] border border-gray-200 w-[420px] max-w-[calc(100vw-2rem)] overflow-hidden shadow-lg">

        <%# Header %>
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
          <p class="text-sm font-semibold text-gray-900" id="add-member-modal-title">
            Add student to <span data-add-member-popup-target="groupName" class="text-[#1F78D1]"></span>
          </p>
          <button data-action="click->add-member-popup#close"
                  class="text-gray-400 hover:text-gray-600 transition-colors"
                  aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" height="18px" viewBox="0 -960 960 960" width="18px" fill="currentColor"><path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"/></svg>
          </button>
        </div>

        <%# Search %>
        <div class="px-5 py-3 border-b border-gray-200">
          <input type="text"
                 data-add-member-popup-target="search"
                 data-action="input->add-member-popup#filter"
                 placeholder="Search students…"
                 class="w-full h-9 px-3 text-sm bg-white border border-gray-300 rounded-[3px] text-black/75 focus:outline-none focus:border-gray-400" />
        </div>

        <%# Student list %>
        <div data-add-member-popup-target="studentList"
             class="max-h-64 overflow-y-auto px-3 py-2"></div>

        <%# Footer %>
        <div class="flex items-center justify-end gap-2 px-5 py-3 border-t border-gray-200">
          <button data-action="click->add-member-popup#close"
                  class="text-xs px-3 py-1.5 border border-gray-300 rounded-[3px] text-gray-600 hover:border-gray-400 hover:text-gray-800 transition-colors">
            Cancel
          </button>
          <button data-add-member-popup-target="confirmBtn"
                  data-action="click->add-member-popup#showConfirm"
                  disabled
                  class="text-xs px-3 py-1.5 bg-[#1F78D1] text-white rounded-[3px] hover:bg-[#1a6abf] transition-colors disabled:opacity-40 disabled:cursor-not-allowed font-medium">
            Add student
          </button>
        </div>
      </div>
    </div>

    <%# Confirm dialog %>
    <div data-add-member-popup-target="confirmOverlay"
         data-action="click->add-member-popup#closeConfirmOnBackdrop"
         class="hidden fixed inset-0 bg-black/50 z-[60] flex items-center justify-center">
      <div class="bg-white rounded-[4px] border border-gray-200 w-[360px] max-w-[calc(100vw-2rem)] px-6 py-5 shadow-lg">
        <p data-add-member-popup-target="confirmTitle"
           class="text-sm font-semibold text-gray-900 mb-2"></p>
        <p data-add-member-popup-target="confirmBody"
           class="text-xs text-gray-500 mb-5 leading-relaxed"></p>
        <div class="flex justify-end gap-2">
          <button data-action="click->add-member-popup#closeConfirm"
                  class="text-xs px-3 py-1.5 border border-gray-300 rounded-[3px] text-gray-600 hover:border-gray-400 transition-colors">
            Cancel
          </button>
          <button data-add-member-popup-target="submitBtn"
                  data-action="click->add-member-popup#submit"
                  class="text-xs px-3 py-1.5 bg-[#1F78D1] text-white rounded-[3px] hover:bg-[#1a6abf] transition-colors font-medium">
            Confirm
          </button>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── Page header %>
  <div>
    <div class="flex items-center gap-3 text-sm text-gray-500">
      <span class="border border-gray-300 rounded px-2 py-0.5">
        <%= @course.student_list_finalised? ? "Fixed list mode" : "Default mode" %>
      </span>
      <span>Group size: <%= @course.group_min %>–<%= @course.group_max %></span>
    </div>
  </div>

  <%# ── Current Group panel %>
  <%= render 'my_group_panel' %>

  <%# ── Browse section: filters + result pane %>
  <div class="flex flex-col md:flex-row md:gap-6">

    <%# Filter sidebar %>
    <div class="w-full md:w-48 md:shrink-0 mb-4 md:mb-0">
      <div class="h-10 flex items-center mb-4">
        <h4 class="text-[0.9375em] font-medium tracking-[1px] uppercase text-[#192325] leading-none">
          Filters
        </h4>
      </div>

      <ul class="list-none space-y-2">
        <li>
          <label class="flex items-center justify-between text-sm text-gray-700 cursor-pointer hover:text-gray-900">
            <span class="flex items-center gap-2">
              <input type="checkbox" class="rounded" name="filter[]" value="looking_for_people" checked />
              Draft — looking for people
            </span>
            <span class="text-xs text-gray-400">8</span>
          </label>
        </li>
        <li>
          <label class="flex items-center justify-between text-sm text-gray-700 cursor-pointer hover:text-gray-900">
            <span class="flex items-center gap-2">
              <input type="checkbox" class="rounded" name="filter[]" value="all_draft" />
              All draft groups
            </span>
            <span class="text-xs text-gray-400">12</span>
          </label>
        </li>
        <li>
          <label class="flex items-center justify-between text-sm text-gray-700 cursor-pointer hover:text-gray-900">
            <span class="flex items-center gap-2">
              <input type="checkbox" class="rounded" name="filter[]" value="no_group" />
              Students without a group
            </span>
            <span class="text-xs text-gray-400">23</span>
          </label>
        </li>
        <li>
          <label class="flex items-center justify-between text-sm text-gray-700 cursor-pointer hover:text-gray-900">
            <span class="flex items-center gap-2">
              <input type="checkbox" class="rounded" name="filter[]" value="confirmed" />
              Confirmed groups
            </span>
            <span class="text-xs text-gray-400">4</span>
          </label>
        </li>
      </ul>
    </div>

    <%# Result pane %>
    <div id="result-pane" class="flex-1 min-w-0">

      <%# Search + sort bar %>
      <div class="flex flex-col sm:flex-row gap-2 mb-4">

        <%# Search input + button %>
        <div class="flex flex-1">
          <input type="text"
                placeholder="Search groups or members…"
                class="flex-1 min-w-0 h-10 px-3 text-[1em] bg-white border-2 border-[#EDF1F2] border-r-0 rounded-none text-black/75 transition-all duration-150 focus:outline-none focus:border-gray-400" />
          <button class="h-10 px-4 text-sm text-white bg-[#1F78D1] border-2 border-[#1F78D1] rounded-none shadow-none font-medium hover:opacity-90 transition-opacity shrink-0">
            Search
          </button>
        </div>

        <%# Sort %>
        <div class="flex items-center gap-2 shrink-0">
          <label class="text-sm text-gray-500 whitespace-nowrap">Sort by</label>
          <select class="h-10 px-3 text-sm border-2 border-[#EDF1F2] rounded-none bg-white text-black/75 focus:outline-none">
            <option>Newest</option>
            <option>Member count</option>
            <option>Name</option>
          </select>
        </div>

      </div>

      <%# Result counts %>
      <p class="text-sm text-gray-600 mb-3">
        <%= @groups.size %> <%= "group".pluralize(@groups.size) %>
        <% if @ungrouped_students.any? %>
          · <%= @ungrouped_students.size %> <%= "student".pluralize(@ungrouped_students.size) %> without a group
        <% end %>
      </p>

      <%# ── Two-column sections: Groups | Ungrouped Students — stack on mobile %>
      <div class="flex flex-col md:flex-row gap-6 items-start">

        <%# ── Groups %>
        <div class="flex-1 min-w-0 w-full">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">
            Groups <span class="normal-case tracking-normal font-normal text-gray-400 ml-1"><%= @groups.size %></span>
          </p>
          <% if @groups.any? %>
            <% @groups.each do |group| %>
              <% is_coordinator = @current_user_enrolment&.coordinator? %>
              <% member_count = group.project_group_members.size %>
              <% is_full = @course.group_max.present? && member_count >= @course.group_max %>
              <% empty_slots = is_coordinator && @course.group_max.present? ? (@course.group_max - member_count) : 0 %>

              <div class="border border-gray-300 rounded-[3px] p-4 bg-white mb-3">

                <%# Badge row %>
                <div class="flex items-start justify-between mb-1 gap-2">
                  <div class="flex items-center gap-1.5 flex-wrap">
                    <% if group.confirmed? %>
                      <span class="inline-block bg-[#1F78D1] text-white text-[0.6875rem] font-normal tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Confirmed</span>
                    <% else %>
                      <span class="inline-block bg-[#475D65] rounded text-white text-[0.6875rem] font-normal tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Draft</span>
                    <% end %>
                    <% if group.locked? %>
                      <span class="inline-block bg-amber-500 text-white text-[0.6875rem] font-normal tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Locked</span>
                    <% end %>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <span class="text-xs text-gray-400">
                      <%= member_count %> / <%= @course.group_max.presence || "?" %>
                    </span>
                    <% unless is_coordinator %>
                      <% if @my_group.nil? && !group.confirmed? && @course.grouping_window_open? %>
                        <% if group.locked? %>
                          <button disabled class="border border-gray-300 rounded px-2 py-0.5 text-xs opacity-40 cursor-not-allowed">Request to join</button>
                        <% else %>
                          <button disabled class="border border-gray-300 rounded px-2 py-0.5 text-xs opacity-40 cursor-not-allowed">Join</button>
                        <% end %>
                      <% end %>
                    <% end %>
                  </div>
                </div>

                <%# Group name %>
                <p class="font-semibold text-base text-gray-900 mb-3">
                  <%= group.group_name.presence || "Unnamed group" %>
                </p>

                <%# ── Member grid (all roles) + empty slots (coordinator only) %>
                <div class="grid grid-cols-2 gap-2">
                  <% group.project_group_members.each do |membership| %>
                    <% member = membership.user %>
                    <div class="flex items-center gap-2.5 p-2.5 rounded-[3px] bg-gray-50 border border-gray-200"
                         data-member-id="<%= member.id %>">
                      <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-200 text-[11px] font-bold text-gray-600 shrink-0">
                        <%= member.name.first.upcase %>
                      </div>
                      <div class="flex flex-col min-w-0">
                        <span class="text-sm font-medium text-gray-900 truncate"><%= member.name %></span>
                        <% if member.instid.present? %>
                          <span class="text-[11px] text-gray-400 font-mono"><%= member.instid %></span>
                        <% end %>
                        <% if membership.user_id == group.leader_id %>
                          <span class="text-[10px] text-[#1F78D1] mt-0.5">leader</span>
                        <% end %>
                      </div>
                      <% if is_coordinator %>
                        <%= button_to course_project_group_member_path(@course, group, member),
                              method: :delete,
                              class: "ml-auto shrink-0 text-[11px] text-red-400 hover:text-red-600 transition-colors self-start pt-0.5",
                              form: { data: { confirm: "Remove #{member.name} from #{group.group_name}? They will become ungrouped." } } do %>
                          Remove
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>

                  <%# Empty slot placeholders — coordinator only, hidden when full %>
                  <% if is_coordinator && !is_full %>
                    <% empty_slots.times do %>
                      <button
                        type="button"
                        data-action="click->add-member-popup#open"
                        data-group-id="<%= group.id %>"
                        data-group-name="<%= j group.group_name %>"
                        class="flex flex-col items-center justify-center gap-1 p-2.5 rounded-[3px] border border-dashed border-gray-300 bg-transparent text-gray-400 hover:border-gray-400 hover:bg-gray-50 hover:text-gray-600 transition-all min-h-[62px] cursor-pointer"
                        aria-label="Add student to <%= group.group_name %>">
                        <div class="w-6 h-6 rounded-full border border-gray-300 flex items-center justify-center">
                          <svg xmlns="http://www.w3.org/2000/svg" height="14px" viewBox="0 -960 960 960" width="14px" fill="currentColor"><path d="M440-440H200v-80h240v-240h80v240h240v80H520v240h-80v-240Z"/></svg>
                        </div>
                        <span class="text-[10px] tracking-wide">Add student</span>
                      </button>
                    <% end %>
                  <% end %>
                </div>

              </div>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-400 py-4">No groups yet.</p>
          <% end %>
        </div>

        <%# ── Ungrouped Students %>
        <div class="w-full md:w-72 md:shrink-0">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">
            Ungrouped Students <span class="normal-case tracking-normal font-normal text-gray-400 ml-1"><%= @ungrouped_students.size %></span>
          </p>
          <% if @ungrouped_students.any? %>
            <div id="ungrouped-students-list" class="flex flex-col gap-2">
              <% @ungrouped_students.each do |student| %>
                <div class="flex items-center gap-2 border border-gray-300 rounded-[3px] px-3 py-2 bg-white"
                     data-student-id="<%= student.id %>"
                     data-student-name="<%= student.name %>"
                     data-student-instid="<%= student.instid %>">
                  <div class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-gray-200 text-[10px] font-bold text-gray-600 shrink-0">
                    <%= student.name.first.upcase %>
                  </div>
                  <div class="leading-tight min-w-0">
                    <span class="text-sm text-gray-800 block truncate"><%= student.name %></span>
                    <% if student.instid.present? %>
                      <span class="text-xs text-gray-400"><%= student.instid %></span>
                    <% end %>
                  </div>
                  <% if @my_group && current_user.id == @my_group.leader_id && @course.grouping_window_open? %>
                    <button disabled class="text-xs text-[#1F78D1] opacity-40 cursor-not-allowed ml-auto shrink-0">Invite</button>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-400 py-4">All students are in a group.</p>
          <% end %>
        </div>

      </div>
    </div>
  </div>
</div>
