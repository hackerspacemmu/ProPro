<%# app/views/project_groups/index.html.erb %>
<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "tailwind", "new_tailwind" %>
<% end %>

<%# --- Disables footer --- %>
<% content_for :no_footer, true %>
<% breadcrumb :course, @course %>

<div class="w-full max-w-[75rem] mx-auto px-6 py-4 space-y-5">

  <%# ── Page header %>
  <div>
    <div class="flex items-center gap-3 text-sm text-gray-500">
      <span class="border border-gray-300 rounded px-2 py-0.5">
        <%= @course.student_list_finalised? ? "Fixed list mode" : "Default mode" %>
      </span>
      <span>Group size: <%= @course.group_min %>–<%= @course.group_max %></span>
    </div>
  </div>

  <%# ── Current Group panel %>
  <%= render 'my_group_panel' %>

  <%# ── Browse section: filters + result pane %>
  <div class="flex flex-col md:flex-row md:gap-6">

    <%# Filter sidebar %>
    <div class="w-full md:w-48 md:shrink-0 mb-4 md:mb-0">
      <div class="h-10 flex items-center mb-4">
        <h4 class="text-[0.9375em] font-medium tracking-[1px] uppercase text-[#192325] leading-none">
          Filters
        </h4>
      </div>

      <ul class="list-none space-y-2">
        <li>
          <label class="flex items-center justify-between text-sm text-gray-700 cursor-pointer hover:text-gray-900">
            <span class="flex items-center gap-2">
              <input type="checkbox" class="rounded" name="filter[]" value="looking_for_people" checked />
              Draft — looking for people
            </span>
            <span class="text-xs text-gray-400">8</span>
          </label>
        </li>
        <li>
          <label class="flex items-center justify-between text-sm text-gray-700 cursor-pointer hover:text-gray-900">
            <span class="flex items-center gap-2">
              <input type="checkbox" class="rounded" name="filter[]" value="all_draft" />
              All draft groups
            </span>
            <span class="text-xs text-gray-400">12</span>
          </label>
        </li>
        <li>
          <label class="flex items-center justify-between text-sm text-gray-700 cursor-pointer hover:text-gray-900">
            <span class="flex items-center gap-2">
              <input type="checkbox" class="rounded" name="filter[]" value="no_group" />
              Students without a group
            </span>
            <span class="text-xs text-gray-400">23</span>
          </label>
        </li>
        <li>
          <label class="flex items-center justify-between text-sm text-gray-700 cursor-pointer hover:text-gray-900">
            <span class="flex items-center gap-2">
              <input type="checkbox" class="rounded" name="filter[]" value="confirmed" />
              Confirmed groups
            </span>
            <span class="text-xs text-gray-400">4</span>
          </label>
        </li>
      </ul>
    </div>

    <%# Result pane %>
    <div id="result-pane" class="flex-1 min-w-0">

      <%# Search + sort bar %>
      <div class="flex flex-col sm:flex-row gap-2 mb-4">

        <%# Search input + button %>
        <div class="flex flex-1">
          <input type="text"
                placeholder="Search groups or members…"
                class="flex-1 min-w-0 h-10 px-3 text-[1em] bg-white border-2 border-[#EDF1F2] border-r-0 rounded-none text-black/75 transition-all duration-150 focus:outline-none focus:border-gray-400" />
          <button class="h-10 px-4 text-sm text-white bg-[#1F78D1] border-2 border-[#1F78D1] rounded-none shadow-none font-medium hover:opacity-90 transition-opacity shrink-0">
            Search
          </button>
        </div>

        <%# Sort %>
        <div class="flex items-center gap-2 shrink-0">
          <label class="text-sm text-gray-500 whitespace-nowrap">Sort by</label>
          <select class="h-10 px-3 text-sm border-2 border-[#EDF1F2] rounded-none bg-white text-black/75 focus:outline-none">
            <option>Newest</option>
            <option>Member count</option>
            <option>Name</option>
          </select>
        </div>

      </div>

      <%# Result counts %>
      <p class="text-sm text-gray-600 mb-3">
        <%= @groups.size %> <%= "group".pluralize(@groups.size) %>
        <% if @ungrouped_students.any? %>
          · <%= @ungrouped_students.size %> <%= "student".pluralize(@ungrouped_students.size) %> without a group
        <% end %>
      </p>

      <%# ── Two-column sections: Groups | Ungrouped Students — stack on mobile %>
      <div class="flex flex-col md:flex-row gap-6 items-start">

        <%# ── Groups %>
        <div class="flex-1 min-w-0 w-full">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">
            Groups <span class="normal-case tracking-normal font-normal text-gray-400 ml-1"><%= @groups.size %></span>
          </p>
          <% if @groups.any? %>
            <% @groups.each do |group| %>
              <div class="border border-gray-200 rounded-[3px] p-4 bg-white mb-3">

                <%# Badge row %>
                <div class="flex items-start justify-between mb-1 gap-2">
                  <div class="flex items-center gap-1.5 flex-wrap">
                    <% if group.confirmed? %>
                      <span class="inline-block bg-[#1F78D1] text-white text-[0.6875rem] font-normal tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Confirmed</span>
                    <% else %>
                      <span class="inline-block bg-[#475D65] rounded text-white text-[0.6875rem] font-normal tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Draft</span>
                    <% end %>
                    <% if group.locked? %>
                      <span class="inline-block bg-amber-500 text-white text-[0.6875rem] font-normal tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Locked</span>
                    <% end %>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <span class="text-xs text-gray-400">
                      <%= group.project_group_members.size %> / <%= @course.group_max.presence || "?" %>
                    </span>
                    <% if @my_group.nil? && !group.confirmed? && @course.grouping_window_open? %>
                      <% if group.locked? %>
                        <button disabled class="border border-gray-300 rounded px-2 py-0.5 text-xs opacity-40 cursor-not-allowed">Request to join</button>
                      <% else %>
                        <button disabled class="border border-gray-300 rounded px-2 py-0.5 text-xs opacity-40 cursor-not-allowed">Join</button>
                      <% end %>
                    <% end %>
                  </div>
                </div>

                <%# Group name %>
                <p class="font-semibold text-base text-gray-900 mb-3">
                  <%= group.group_name.presence || "Unnamed group" %>
                </p>

                <%# Member list %>
                <ul class="space-y-1.5">
                  <% group.project_group_members.each do |membership| %>
                    <li class="flex items-center gap-2">
                      <div class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-gray-200 text-[10px] font-bold text-gray-600 shrink-0">
                        <%= membership.user.name.first.upcase %>
                      </div>
                      <span class="text-sm text-gray-600 truncate"><%= membership.user.name %></span>
                      <% if membership.user_id == group.leader_id %>
                        <span class="text-xs text-gray-400 shrink-0">(leader)</span>
                      <% end %>
                      <button disabled class="ml-auto text-xs text-red-400 opacity-40 cursor-not-allowed shrink-0">Kick</button>
                    </li>
                  <% end %>
                </ul>

              </div>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-400 py-4">No groups yet.</p>
          <% end %>
        </div>

        <%# ── Ungrouped Students %>
        <div class="w-full md:w-72 md:shrink-0">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">
            Ungrouped Students <span class="normal-case tracking-normal font-normal text-gray-400 ml-1"><%= @ungrouped_students.size %></span>
          </p>
          <% if @ungrouped_students.any? %>
            <div class="flex flex-col gap-2">
              <% @ungrouped_students.each do |student| %>
                <div class="flex items-center gap-2 border border-gray-200 rounded-[3px] px-3 py-2 bg-white">
                  <div class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-gray-200 text-[10px] font-bold text-gray-600 shrink-0">
                    <%= student.name.first.upcase %>
                  </div>
                  <div class="leading-tight min-w-0">
                    <span class="text-sm text-gray-800 block truncate"><%= student.name %></span>
                    <% if student.instid.present? %>
                      <span class="text-xs text-gray-400"><%= student.instid %></span>
                    <% end %>
                  </div>
                  <% if @my_group && current_user.id == @my_group.leader_id && @course.grouping_window_open? %>
                    <button disabled class="text-xs text-[#1F78D1] opacity-40 cursor-not-allowed ml-auto shrink-0">Invite</button>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-400 py-4">All students are in a group.</p>
          <% end %>
        </div>

      </div>
    </div>
  </div>
</div>