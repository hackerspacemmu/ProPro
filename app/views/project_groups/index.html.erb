<%# Merged coordinator_actions.html.erb — YingTong settings + Alex modal flow %>
<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "tailwind", "new_tailwind" %>
<% end %>

<% content_for :no_footer, true %>
<% breadcrumb :coordinator_actions, @course %>

<div id="flash">
  <%= render "courses/flash" %>
</div>

<%#
  data-controller on outermost div so all modal open buttons (inside group cards)
  are descendants of the same controller instance.
  base-url-value is the project_groups path — JS appends /:group_id/members.
%>
<div class="w-full max-w-[75rem] mx-auto px-6 py-4 space-y-5"
     data-controller="add-member-modal"
     data-add-member-modal-base-url-value="<%= course_project_groups_path(@course) %>">

  <%# ── Add-member modal — single instance, shared across all groups %>
  <div data-add-member-modal-target="overlay"
       data-action="click->add-member-modal#closeOnBackdrop"
       class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center"
       role="dialog" aria-modal="true" aria-labelledby="add-member-modal-title">
    <div class="bg-white rounded-[4px] border border-gray-200 w-[420px] max-w-[calc(100vw-2rem)] overflow-hidden shadow-lg">

      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
        <p class="text-sm font-semibold text-gray-900" id="add-member-modal-title">Add student to group</p>
        <button data-action="click->add-member-modal#close"
                class="text-gray-400 hover:text-gray-600 transition-colors"
                aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" height="18px" viewBox="0 -960 960 960" width="18px" fill="currentColor">
            <path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"/>
          </svg>
        </button>
      </div>

      <%# Search — filters <option> elements via Stimulus %>
      <div class="px-5 py-3 border-b border-gray-200">
        <input type="text"
               data-add-member-modal-target="search"
               data-action="input->add-member-modal#filter"
               placeholder="Search students…"
               class="w-full h-9 px-3 text-sm bg-white border border-gray-300 rounded-[3px] text-black/75 focus:outline-none focus:border-gray-400" />
      </div>

      <%# Form action is set by Stimulus open() based on data-group-id on the trigger button %>
      <%= form_with url: "#",
            method: :post,
            data: { "add-member-modal-target": "form" },
            class: "px-5 py-4" do |f| %>

        <%#
          Wrapped in a stable ID so Turbo Stream can replace just the select
          after each add, keeping the rest of the modal intact.
        %>
        <div id="modal-ungrouped-select">
          <%= render "modal_ungrouped_students", ungrouped_students: @ungrouped_students %>
        </div>

        <div class="flex justify-end gap-2 mt-4">
          <button type="button"
                  data-action="click->add-member-modal#close"
                  class="text-xs px-3 py-1.5 border border-gray-300 rounded-[3px] text-gray-600 hover:border-gray-400 hover:text-gray-800 transition-colors">
            Cancel
          </button>
          <%= f.submit "Add student",
                data: { turbo_confirm: "Add this student to the group?" },
                class: "text-xs px-3 py-1.5 bg-[#1F78D1] text-white rounded-[3px] hover:bg-[#1a6abf] transition-colors font-medium cursor-pointer" %>
        </div>
      <% end %>

    </div>
  </div>

  <%# ── Settings panel
        Three separate forms, each with an explicit submit button.
        No auto-submit. No Stimulus on these forms.
        Conditional sections are server-rendered — redirect re-renders the page.
  %>
  <div class="bg-white border border-gray-200 rounded-[3px] p-5 mb-8 shadow-sm flex flex-col gap-4">

    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        <h3 class="text-sm font-bold text-[#192325] uppercase tracking-wide">Grouping System</h3>

        <%= form_with url: update_settings_course_project_groups_path(@course), method: :patch, class: "flex items-center gap-2" do |f| %>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="hidden" name="grouping_enabled" value="0">
            <input type="checkbox" name="grouping_enabled" value="1"
                   class="sr-only peer"
                   <%= "checked" if @course.grouping_enabled? %>>
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
          </label>
          <span class="text-sm font-black tracking-widest <%= @course.grouping_enabled? ? 'text-green-600' : 'text-gray-400' %> w-8">
            <%= @course.grouping_enabled? ? "ON" : "OFF" %>
          </span>
          <%= f.submit "Save", class: "text-xs px-3 py-1.5 bg-[#1F78D1] text-white rounded-[3px] hover:bg-[#1a6abf] transition-colors font-medium cursor-pointer" %>
        <% end %>
      </div>

      <% if @course.grouping_enabled? %>
        <div class="flex items-center gap-3 border-l border-gray-200 pl-4">
          <span class="text-sm font-medium text-gray-600">Student Window:</span>
          <%= form_with url: update_settings_course_project_groups_path(@course), method: :patch, class: "flex items-center gap-2" do |f| %>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="hidden" name="grouping_open" value="0">
              <input type="checkbox" name="grouping_open" value="1"
                     class="sr-only peer"
                     <%= "checked" if @course.grouping_window_open? %>>
              <div class="w-9 h-5 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-[#1F78D1]"></div>
            </label>
            <span class="text-xs font-bold <%= @course.grouping_window_open? ? 'text-[#1F78D1]' : 'text-gray-400' %> w-12">
              <%= @course.grouping_window_open? ? "OPEN" : "CLOSED" %>
            </span>
            <%= f.submit "Save", class: "text-xs px-3 py-1.5 bg-[#1F78D1] text-white rounded-[3px] hover:bg-[#1a6abf] transition-colors font-medium cursor-pointer" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @course.grouping_enabled? %>
      <div class="border-t border-gray-100 pt-4 mt-1">
        <%= form_with url: update_settings_course_project_groups_path(@course), method: :patch do |f| %>
          <div class="flex flex-col md:flex-row gap-4">

            <label class="flex-1 border <%= !@course.student_list_finalised? ? 'border-[#1F78D1] bg-blue-50/30 shadow-sm' : 'border-gray-200 bg-gray-50/50 opacity-60' %> rounded-[3px] p-3 cursor-pointer hover:border-[#1F78D1] hover:opacity-100 transition-all">
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 mt-1">
                  <input type="radio" name="student_list_finalised" value="0"
                         class="w-4 h-4 text-[#1F78D1] focus:ring-[#1F78D1]"
                         <%= "checked" unless @course.student_list_finalised? %>>
                </div>
                <div>
                  <h4 class="text-sm font-bold text-gray-900">Default Mode</h4>
                  <p class="text-xs text-gray-500 mt-1 leading-relaxed">Student list is <span class="font-semibold">not final</span>. No student self-grouping. Coordinator manages all groups manually via CRUD. Students can only view their assigned group.</p>
                </div>
              </div>
            </label>

            <label class="flex-1 border <%= @course.student_list_finalised? ? 'border-[#1F78D1] bg-blue-50/30 shadow-sm' : 'border-gray-200 bg-gray-50/50 opacity-60' %> rounded-[3px] p-3 cursor-pointer hover:border-[#1F78D1] hover:opacity-100 transition-all">
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 mt-1">
                  <input type="radio" name="student_list_finalised" value="1"
                         class="w-4 h-4 text-[#1F78D1] focus:ring-[#1F78D1]"
                         <%= "checked" if @course.student_list_finalised? %>>
                </div>
                <div>
                  <h4 class="text-sm font-bold text-gray-900">Fixed List Mode</h4>
                  <p class="text-xs text-gray-500 mt-1 leading-relaxed">Student list is <span class="font-semibold">final</span>. Students can self-group and send invites. Coordinators oversee draft groups and manually confirm them.</p>
                </div>
              </div>
            </label>

          </div>
          <div class="mt-3 flex justify-end">
            <%= f.submit "Save mode", class: "text-xs px-3 py-1.5 bg-[#1F78D1] text-white rounded-[3px] hover:bg-[#1a6abf] transition-colors font-medium cursor-pointer" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="border-t border-gray-100 pt-4 mt-1">
        <p class="text-sm text-gray-400 italic">Grouping is currently disabled for this course. Turn it ON to configure modes.</p>
      </div>
    <% end %>
  </div>

  <%# ── Warning banners %>
  <div class="border border-red-300 bg-red-50 rounded-[3px] p-4 flex items-start gap-3 mb-6">
    <span class="text-red-500 text-lg leading-none mt-0.5">⚠️</span>
    <div>
      <h3 class="text-[0.8rem] font-bold text-red-800 tracking-widest uppercase">Grouping in ProPro is Still In Development!</h3>
      <p class="text-sm text-red-700 mt-1">The Grouping Features that you see here are still Work In Progress. Do not use them for your classes yet.</p>
    </div>
  </div>

  <% unless @course.student_list_finalised? %>
    <div class="border border-amber-300 bg-amber-50 rounded-[3px] p-4 flex items-start gap-3 mb-6">
      <div>
        <h3 class="text-[0.8rem] font-bold text-amber-800 tracking-widest uppercase">Default Mode Active</h3>
        <p class="text-sm text-amber-700 mt-1">Students cannot self-group. All draft groups must be manually confirmed by a coordinator.</p>
      </div>
    </div>
  <% end %>

  <%# ── Two-column layout %>
  <div class="flex flex-col md:flex-row gap-6 items-start">

    <%# ── LEFT: Ungrouped Students sidebar %>
    <div class="w-full md:w-80 md:shrink-0 flex flex-col h-[800px]">
      <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3 flex justify-between items-center">
        <span>Ungrouped Students</span>
        <span class="normal-case tracking-normal font-normal text-gray-400"><%= @ungrouped_students.count %></span>
      </p>
      <div class="border border-gray-200 rounded-[3px] bg-white flex flex-col h-full overflow-hidden">
        <div id="ungrouped-students-list" class="overflow-y-auto flex-1 p-3 space-y-2">
          <% @ungrouped_students.each do |student| %>
            <div class="flex items-center gap-2 px-2 py-1.5 rounded-[3px] hover:bg-gray-50"
                data-student-id="<%= student.id %>"
                data-student-name="<%= student.name %>">
              <div class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-200 text-[10px] font-bold text-gray-600 shrink-0">
                <%= student.name.first.upcase %>
              </div>
              <div class="leading-tight min-w-0">
                <span class="text-sm text-gray-800 block truncate"><%= student.name %></span>
                <% if student.instid.present? %>
                  <span class="text-xs text-gray-400"><%= student.instid %></span>
                <% end %>
              </div>
            </div>
          <% end %>
          <% if @ungrouped_students.empty? %>
            <p class="text-sm text-gray-400 py-2 text-center">All students are grouped.</p>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── RIGHT: Groups %>
    <div class="flex-1 min-w-0 w-full">
      <div class="flex items-center justify-between mb-4">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400">
          Groups <span class="normal-case tracking-normal font-normal text-gray-400 ml-1"><%= @groups.size %></span>
        </p>
      </div>

      <%# Draft Groups %>
      <div class="mb-10">
        <h4 class="text-[0.9375em] font-medium tracking-[1px] uppercase text-[#192325] leading-none mb-4 pb-2 border-b border-gray-200">
          Draft Groups
        </h4>
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
          <% @groups.select(&:confirmed?).each do |group| %>
            <% member_count = group.project_group_members.size %>
            <% is_full = @course.group_max.present? && member_count >= @course.group_max %>
            <% empty_slots = @course.group_max.present? ? (@course.group_max - member_count) : 0 %>
            <div class="border border-gray-200 rounded-[3px] p-4 bg-white shadow-sm">
              <div class="flex items-start justify-between mb-2 gap-2">
                <div class="flex items-center gap-1.5 flex-wrap">
                  <span class="inline-block bg-[#1F78D1] text-white text-[0.6875rem] tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Confirmed</span>
                  <% if group.locked? %>
                    <span class="inline-block bg-amber-500 text-white text-[0.6875rem] tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Locked</span>
                  <% end %>
                </div>
                <span class="text-xs text-gray-400 shrink-0"><%= member_count %> / <%= @course.group_max.presence || "?" %></span>
              </div>
              <p class="font-semibold text-base text-gray-900 mb-3"><%= group.group_name.presence || "Unnamed group" %></p>
              <div class="grid grid-cols-2 gap-2">
                <% group.project_group_members.each do |membership| %>
                  <% member = membership.user %>
                  <div class="flex items-center gap-2.5 p-2.5 rounded-[3px] bg-gray-50 border border-gray-200">
                    <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-200 text-[11px] font-bold text-gray-600 shrink-0">
                      <%= member.name.first.upcase %>
                    </div>
                    <div class="flex flex-col min-w-0">
                      <span class="text-sm font-medium text-gray-900 truncate"><%= member.name %></span>
                      <% if member.instid.present? %>
                        <span class="text-[11px] text-gray-400 font-mono"><%= member.instid %></span>
                      <% end %>
                      <% if membership.user_id == group.leader_id %>
                        <span class="text-[10px] text-[#1F78D1] mt-0.5">leader</span>
                      <% end %>
                    </div>
                    <%= button_to course_project_group_member_path(@course, group, member),
                          method: :delete,
                          class: "ml-auto shrink-0 text-[11px] text-red-400 hover:text-red-600 transition-colors self-start pt-0.5",
                          form: { data: { turbo_confirm: "Remove #{member.name} from #{group.group_name}? They will become ungrouped." } } do %>
                      Remove
                    <% end %>
                  </div>
                <% end %>
                <% unless is_full %>
                  <% empty_slots.times do %>
                    <button type="button"
                            data-action="click->add-member-modal#open"
                            data-group-id="<%= group.id %>"
                            data-group-name="<%= j group.group_name %>"
                            class="flex flex-col items-center justify-center gap-1 p-2.5 rounded-[3px] border border-dashed border-gray-300 bg-transparent text-gray-400 hover:border-gray-400 hover:bg-gray-50 hover:text-gray-600 transition-all min-h-[62px] cursor-pointer">
                      <div class="w-6 h-6 rounded-full border border-gray-300 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" height="14px" viewBox="0 -960 960 960" width="14px" fill="currentColor"><path d="M440-440H200v-80h240v-240h80v240h240v80H520v240h-80v-240Z"/></svg>
                      </div>
                      <span class="text-[10px] tracking-wide">Add student</span>
                    </button>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        <% if @groups.reject(&:confirmed?).empty? %>
          <p class="text-sm text-gray-400 py-2">No draft groups present.</p>
        <% end %>
      </div>

      <%# Confirmed Groups %>
      <div>
        <h4 class="text-[0.9375em] font-medium tracking-[1px] uppercase text-[#192325] leading-none mb-4 pb-2 border-b border-gray-200">
          Confirmed Groups
        </h4>
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
          <% @groups.select(&:confirmed?).each do |group| %>
            <% member_count = group.project_group_members.size %>
            <% is_full = @course.group_max.present? && member_count >= @course.group_max %>
            <% empty_slots = @course.group_max.present? ? (@course.group_max - member_count) : 0 %>
            <div class="border border-gray-200 rounded-[3px] p-4 bg-white shadow-sm">
              <div class="flex items-start justify-between mb-2 gap-2">
                <div class="flex items-center gap-1.5 flex-wrap">
                  <span class="inline-block bg-[#1F78D1] text-white text-[0.6875rem] tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Confirmed</span>
                  <% if group.locked? %>
                    <span class="inline-block bg-amber-500 text-white text-[0.6875rem] tracking-[1px] leading-none px-[0.625em] py-[0.4375em]">Locked</span>
                  <% end %>
                </div>
                <span class="text-xs text-gray-400 shrink-0"><%= member_count %> / <%= @course.group_max.presence || "?" %></span>
              </div>
              <p class="font-semibold text-base text-gray-900 mb-3"><%= group.group_name.presence || "Unnamed group" %></p>
              <div class="grid grid-cols-2 gap-2">
                <% group.project_group_members.each do |membership| %>
                  <% member = membership.user %>
                  <div class="flex items-center gap-2.5 p-2.5 rounded-[3px] bg-gray-50 border border-gray-200">
                    <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-200 text-[11px] font-bold text-gray-600 shrink-0">
                      <%= member.name.first.upcase %>
                    </div>
                    <div class="flex flex-col min-w-0">
                      <span class="text-sm font-medium text-gray-900 truncate"><%= member.name %></span>
                      <% if member.instid.present? %>
                        <span class="text-[11px] text-gray-400 font-mono"><%= member.instid %></span>
                      <% end %>
                      <% if membership.user_id == group.leader_id %>
                        <span class="text-[10px] text-[#1F78D1] mt-0.5">leader</span>
                      <% end %>
                    </div>
                    <%= button_to course_project_group_member_path(@course, group, member),
                          method: :delete,
                          class: "ml-auto shrink-0 text-[11px] text-red-400 hover:text-red-600 transition-colors self-start pt-0.5",
                          form: { data: { turbo_confirm: "Remove #{member.name} from #{group.group_name}? They will become ungrouped." } } do %>
                      Remove
                    <% end %>
                  </div>
                <% end %>
                <% unless is_full %>
                  <% empty_slots.times do %>
                    <button type="button"
                            data-action="click->add-member-modal#open"
                            data-group-id="<%= group.id %>"
                            data-group-name="<%= j group.group_name %>"
                            class="flex flex-col items-center justify-center gap-1 p-2.5 rounded-[3px] border border-dashed border-gray-300 bg-transparent text-gray-400 hover:border-gray-400 hover:bg-gray-50 hover:text-gray-600 transition-all min-h-[62px] cursor-pointer">
                      <div class="w-6 h-6 rounded-full border border-gray-300 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" height="14px" viewBox="0 -960 960 960" width="14px" fill="currentColor"><path d="M440-440H200v-80h240v-240h80v240h240v80H520v240h-80v-240Z"/></svg>
                      </div>
                      <span class="text-[10px] tracking-wide">Add student</span>
                    </button>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        <% if @groups.select(&:confirmed?).empty? %>
          <p class="text-sm text-gray-400 py-2">No confirmed groups yet.</p>
        <% end %>
      </div>
    </div>

  </div>
</div>
