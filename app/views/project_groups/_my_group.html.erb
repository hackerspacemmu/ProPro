<article>
  <header>
    <h2>
      My Group
      <% if group.confirmed? %>
        <span>(Confirmed)</span>
      <% else %>
        <span>(Draft)</span>
      <% end %>
    </h2>

    <% if group.group_name.present? %>
      <p><%= group.group_name %></p>
    <% else %>
      <p>Name assigned at confirmation</p>
    <% end %>

    <% if group.locked? %>
      <p>This group is locked</p>
    <% else %>
      <p>This group is open</p>
    <% end %>
  </header>

  <section>
    <h3>Members (<%= group.project_group_members.count %>)</h3>
    <ul>
      <% group.project_group_members.each do |membership| %>
        <li>
          <%= membership.user.name %>
          <% if membership.user_id == group.leader_id %>
            <span>(Leader)</span>
          <% end %>

          <%# Leader only — kick member %>
          <% if current_user.id == group.leader_id && @course.grouping_window_open? %>
            <%# TODO Person 2: DELETE course_project_group_member_path %>
            <button type="button" disabled>Kick</button>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>

  <%# Pending invites and requests %>
  <section>
    <h3>Pending Invites &amp; Requests</h3>
    <p>Invite and request management coming soon (Person 3).</p>
  </section>

  <%# Leader actions %>
  <% if current_user.id == group.leader_id && @course.grouping_window_open? %>
    <section>
      <h3>Leader Actions</h3>

      <% if group.confirmed? %>
        <%# TODO Person 2: PATCH revert_course_project_group_path %>
        <button type="button" disabled>Revert to draft</button>
      <% else %>
        <%# TODO Person 2: PATCH confirm_course_project_group_path %>
        <button type="button" disabled>Confirm group</button>
      <% end %>

      <% if group.locked? %>
        <%# TODO Person 2: unlock action %>
        <button type="button" disabled>Unlock group</button>
      <% else %>
        <%# TODO Person 2: lock action %>
        <button type="button" disabled>Lock group</button>
      <% end %>
    </section>
  <% end %>

  <%# Leave group — any member, Person 2 %>
  <% if @course.grouping_window_open? %>
    <%# TODO Person 2: DELETE course_project_group_path (or a dedicated leave route) %>
    <button type="button" disabled>Leave group</button>
  <% end %>
</article>