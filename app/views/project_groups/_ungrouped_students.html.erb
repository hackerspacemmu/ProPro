<% if students.empty? %>
  <p>All enrolled students are in a group.</p>
<% else %>
  <ul>
    <% students.each do |student| %>
      <li>
        <%= student.name %>
        <%= student.email_address %>

        <%# Coordinator only — add student to a group %>
        <% if @current_user_enrolment&.coordinator? %>
          <%# TODO Person 1: form or button to move student into a group %>
          <button type="button" disabled>Add to group</button>
        <% end %>
      </li>
    <% end %>
  </ul>
<% end %>