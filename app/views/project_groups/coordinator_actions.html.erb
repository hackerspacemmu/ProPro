<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "tailwind", "new_tailwind" %>
<% end %>

<% content_for :no_footer, true %>
<% breadcrumb :coordinator_actions, @course %>
<div id="flash">
  <%= render "courses/flash" %>
</div>
<div class="w-full max-w-[75rem] mx-auto px-6 py-4 space-y-5">

  <div
    class="
      bg-white border border-gray-200 rounded-[3px] p-5 mb-8 shadow-sm flex flex-col
      gap-4
    "
  >

    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        <h3 class="text-sm font-bold text-[#192325] uppercase tracking-wide">Grouping System</h3>

        <%= form_with url: update_settings_course_project_groups_path(@course), method: :patch, data: { controller: "auto-submit" }, class: "flex items-center gap-2" do |f| %>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="hidden" name="grouping_enabled" value="0">
            <input
              type="checkbox"
              name="grouping_enabled"
              value="1"
              class="sr-only peer"
              data-action="change->auto-submit#submit"
              <%= "checked" if @course.grouping_enabled? %>
            >
            <div
              class="
                w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer
                peer-checked:after:translate-x-full peer-checked:after:border-white
                after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5
                after:w-5 after:transition-all peer-checked:bg-green-500
              "
            ></div>
          </label>
          <span
            class="
              text-sm font-black tracking-widest <%= @course.grouping_enabled? ? 'text-green-600' : 'text-gray-400' %> w-8
            "
          >
            <%= @course.grouping_enabled? ? "ON" : "OFF" %>
          </span>
        <% end %>
      </div>

      <%# Grouping Window Toggle (Only visible if Grouping is ON) %>
      <% if @course.grouping_enabled? %>
        <div class="flex items-center gap-3 border-l border-gray-200 pl-4">
          <span class="text-sm font-medium text-gray-600">Student Window:</span>
          <%= form_with url: update_settings_course_project_groups_path(@course), method: :patch, data: { controller: "auto-submit" }, class: "flex items-center gap-2" do |f| %>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="hidden" name="grouping_open" value="0">
              <input
                type="checkbox"
                name="grouping_open"
                value="1"
                class="sr-only peer"
                data-action="change->auto-submit#submit"
                <%= "checked" if @course.grouping_window_open? %>
              >
              <div
                class="
                  w-9 h-5 bg-gray-200 peer-focus:outline-none rounded-full peer
                  peer-checked:after:translate-x-full peer-checked:after:border-white
                  after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                  after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4
                  after:w-4 after:transition-all peer-checked:bg-[#1F78D1]
                "
              ></div>
            </label>
            <span
              class="
                text-xs font-bold <%= @course.grouping_window_open? ? 'text-[#1F78D1]' : 'text-gray-400' %> w-12
              "
            >
              <%= @course.grouping_window_open? ? "OPEN" : "CLOSED" %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Mode Selector (Only visible if Grouping is ON) %>
    <% if @course.grouping_enabled? %>
      <div class="border-t border-gray-100 pt-4 mt-1">
        <%= form_with url: update_settings_course_project_groups_path(@course), method: :patch, data: { controller: "auto-submit" } do |f| %>
          <div class="flex flex-col md:flex-row gap-4">

            <%# Default Mode Card %>
            <label
              class="
                flex-1 border <%= !@course.student_list_finalised? ? 'border-[#1F78D1] bg-blue-50/30 shadow-sm' : 'border-gray-200 bg-gray-50/50 opacity-60' %> rounded-[3px] p-3
                cursor-pointer hover:border-[#1F78D1] hover:opacity-100 transition-all
              "
            >
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 mt-1">
                  <input
                    type="radio"
                    name="student_list_finalised"
                    value="0"
                    class="w-4 h-4 text-[#1F78D1] focus:ring-[#1F78D1]"
                    data-action="change->auto-submit#submit"
                    <%= "checked" unless @course.student_list_finalised? %>
                  >
                </div>
                <div>
                  <h4 class="text-sm font-bold text-gray-900">Default Mode</h4>
                  <p class="text-xs text-gray-500 mt-1 leading-relaxed">Student list is
                    <span class="font-semibold">not final</span>. No student self-grouping. Coordinator manages all groups
                    manually via CRUD. Students can only view their assigned
                    group.</p>
                </div>
              </div>
            </label>

            <%# Fixed List Mode Card %>
            <label
              class="
                flex-1 border <%= @course.student_list_finalised? ? 'border-[#1F78D1] bg-blue-50/30 shadow-sm' : 'border-gray-200 bg-gray-50/50 opacity-60' %> rounded-[3px] p-3
                cursor-pointer hover:border-[#1F78D1] hover:opacity-100 transition-all
              "
            >
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 mt-1">
                  <input
                    type="radio"
                    name="student_list_finalised"
                    value="1"
                    class="w-4 h-4 text-[#1F78D1] focus:ring-[#1F78D1]"
                    data-action="change->auto-submit#submit"
                    <%= "checked" if @course.student_list_finalised? %>
                  >
                </div>
                <div>
                  <h4 class="text-sm font-bold text-gray-900">Fixed List Mode</h4>
                  <p class="text-xs text-gray-500 mt-1 leading-relaxed">Student list is
                    <span class="font-semibold">final</span>. Students can self-group and send invites. Coordinators
                    oversee draft groups and manually confirm them.</p>
                </div>
              </div>
            </label>

          </div>
        <% end %>
      </div>
    <% else %>
      <%# State when grouping is OFF %>
      <div class="border-t border-gray-100 pt-4 mt-1">
        <p class="text-sm text-gray-400 italic">Grouping is currently disabled for this course. Turn it ON to
          configure modes.</p>
      </div>
    <% end %>
  </div>

  <%# ── Warning Banner For ProPro's Incomplete Grouping Feature %>
  <div
    class="
      border border-red-300 bg-red-50 rounded-[3px] p-4 flex items-start gap-3 mb-6
    "
  >
    <span class="text-red-500 text-lg leading-none mt-0.5">⚠️</span>
    <div>
      <h3 class="text-[0.8rem] font-bold text-red-800 tracking-widest uppercase">Grouping in ProPro is Still In Development!</h3>
      <p class="text-sm text-red-700 mt-1">
        The Grouping Features that you see here are still Work In Progress. Do
        not use them for your classes yet.
      </p>
    </div>
  </div>

  <%# ── Warning Banner %>
  <% unless @course.student_list_finalised? %>
    <div
      class="
        border border-amber-300 bg-amber-50 rounded-[3px] p-4 flex items-start gap-3
        mb-6
      "
    >
      <div>
        <h3 class="text-[0.8rem] font-bold text-amber-800 tracking-widest uppercase">Default Mode Active</h3>
        <p class="text-sm text-amber-700 mt-1">Students cannot self-group. All draft groups must be manually
          confirmed by a coordinator.</p>
      </div>
    </div>
  <% end %>

  <%# ── Two-column layout %>
  <div class="flex flex-col md:flex-row gap-6 items-start">

    <%# ── LEFT COLUMN: Ungrouped Students ── %>
    <div class="w-full md:w-80 md:shrink-0 flex flex-col h-[800px]">
      <p
        class="
          text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3 flex
          justify-between items-center
        "
      >
        <span>Ungrouped Students</span>
        <span class="normal-case tracking-normal font-normal text-gray-400"><%= @ungrouped_students.count %></span>
      </p>

      <div
        class="
          border border-gray-200 rounded-[3px] bg-white flex flex-col h-full
          overflow-hidden
        "
      >
        <div class="p-3 border-b border-gray-100 bg-[#fdfdfd]">
          <input
            type="text"
            placeholder="Search by name..."
            class="
              w-full h-10 px-3 text-[1em] bg-white border-2 border-[#EDF1F2] rounded-none
              text-black/75 transition-all duration-150 focus:outline-none
              focus:border-gray-400
            "
            autocomplete="off"
          >
        </div>

        <div class="overflow-y-auto flex-1 p-3 space-y-2">
          <% if @ungrouped_students.empty? %>
            <p class="text-sm text-gray-400 py-4 text-center">All students are in a group.</p>
          <% end %>

          <% @ungrouped_students.each do |student| %>
            <div
              class="
                flex flex-col gap-2 border border-gray-100 rounded-[3px] p-2.5
                hover:border-[#1F78D1]/40 transition-colors group
              "
            >
              <div class="flex items-center gap-2 min-w-0">
                <div
                  class="
                    inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-200
                    text-[10px] font-bold text-gray-600 shrink-0
                  "
                >
                  <%= student.name.presence&.first&.upcase || "?" %>
                </div>
                <div class="leading-tight min-w-0">
                  <span class="text-sm text-gray-800 block truncate font-medium"><%= student.name.presence || student.email_address %></span>
                  <% if student.instid.present? %>
                    <span class="text-xs text-gray-400"><%= student.instid %></span>
                  <% end %>
                </div>
              </div>

              <%# Add Action (Hidden until hover) %>
              <%= form_with url: "#", method: :post,
                    data: {
                      controller: "dynamic-form-action",
                      dynamic_form_action_base_url_value: "/courses/#{@course.id}/project_groups",
                      dynamic_form_action_endpoint_value: "project_groups_coordinator_actions/add"
                    },
                    class: "hidden group-hover:flex items-center gap-2 mt-1" do |f| %>

                <%= f.hidden_field :user_id, value: student.id %>

                <select
                  class="
                    flex-1 h-8 px-2 text-xs bg-white border-2 border-[#EDF1F2] rounded-none
                    text-black/75 focus:outline-none focus:border-gray-400 cursor-pointer
                  "
                  data-action="change->dynamic-form-action#update"
                  required
                >
                  <option value="" disabled selected>Select Target Group...</option>
                  <% @groups.each do |g| %>
                    <option value="<%= g.id %>"><%= g.group_name.presence || "Grp #{g.id}" %>
                      (<%= g.project_group_members.size %>)</option>
                  <% end %>
                </select>

                <%= f.submit "Add",
                         class:
                           "h-8 px-3 text-xs text-white bg-[#1F78D1] border-2 border-[#1F78D1] rounded-none shadow-none font-medium hover:opacity-90 transition-opacity cursor-pointer shrink-0" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── RIGHT COLUMN: Course Groups ── %>
    <div class="flex-1 min-w-0 w-full">

      <div class="flex items-center justify-between mb-4">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400">
          Groups
          <span class="normal-case tracking-normal font-normal text-gray-400 ml-1"><%= @groups.size %></span>
        </p>
        <div class="flex items-center gap-2">
          <input
            type="text"
            placeholder="Search groups..."
            class="
              h-10 px-3 text-[1em] bg-white border-2 border-[#EDF1F2] rounded-none
              text-black/75 focus:outline-none focus:border-gray-400 w-48 md:w-64
            "
            autocomplete="off"
          >
        </div>
      </div>

      <%# ================= DRAFT GROUPS ================= %>
      <div class="mb-10">
        <h4
          class="
            text-[0.9375em] font-medium tracking-[1px] uppercase text-[#192325] leading-none
            mb-4 pb-2 border-b border-gray-200
          "
        >
          Draft Groups
        </h4>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
          <% @groups.reject(&:confirmed?).each do |group| %>
            <% is_over_limit = group.project_group_members.size > @course.group_max.to_i %>

            <div
              class="
                border <%= is_over_limit ? 'border-red-300 bg-[#fffafa]' : 'border-gray-200 bg-white' %> rounded-[3px] flex flex-col h-full
                relative
              "
            >
              <div class="p-4 flex-1">

                <%# Badges %>
                <div class="flex items-start justify-between mb-3 gap-2">
                  <div class="flex items-center gap-1.5 flex-wrap">
                    <span
                      class="
                        inline-block bg-[#475D65] rounded text-white text-[0.6875rem] font-normal
                        tracking-[1px] leading-none px-[0.625em] py-[0.4375em]
                      "
                    >Draft</span>
                    <% if group.locked? %>
                      <span
                        class="
                          inline-block bg-amber-500 rounded text-white text-[0.6875rem] font-normal
                          tracking-[1px] leading-none px-[0.625em] py-[0.4375em]
                        "
                      >Locked</span>
                    <% end %>
                  </div>
                  <span
                    class="text-xs <%= is_over_limit ? 'text-red-600 font-bold' : 'text-gray-400' %>"
                  >
                    <%= is_over_limit ? "⚠️ " : "" %><%= group.project_group_members.size %>
                    /
                    <%= @course.group_max %>
                  </span>
                </div>

                <p
                  class="
                    font-semibold text-base <%= is_over_limit ? 'text-red-800' : 'text-gray-900' %> mb-4
                  "
                >
                  <%= group.group_name.presence || "Unnamed Draft Group" %>
                </p>

                <%# Members %>
                <ul class="space-y-3">
                  <% group.project_group_members.each do |membership| %>
                    <li class="flex items-center gap-2 group/member">
                      <div
                        class="
                          inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-200
                          text-[10px] font-bold text-gray-600 shrink-0
                        "
                      >
                        <%= membership.user.name.presence&.first&.upcase || "?" %>
                      </div>
                      <div class="min-w-0 flex-1">
                        <span class="text-sm text-gray-800 truncate block"><%= membership.user.name.presence || membership.user.email_address %></span>
                        <% if membership.user_id == group.leader_id %>
                          <span class="text-[10px] text-gray-400 uppercase tracking-wide leading-none">(leader)</span>
                        <% end %>
                      </div>

                      <%# Hover Actions (Move & Remove) %>
                      <div
                        class="
                          opacity-0 group-hover/member:opacity-100 flex items-center gap-3 shrink-0
                          transition-opacity
                        "
                      >
                        <%= form_with url: move_course_project_group_project_groups_coordinator_actions_path(@course, group),
                              method: :post,
                              data: { controller: "auto-submit" },
                              class: "inline" do |f| %>
                          <%= f.hidden_field :user_id, value: membership.user_id %>
                          <select
                            name="target_group_id"
                            class="
                              text-xs border border-gray-300 rounded-[2px] py-0.5 px-1 text-gray-600
                              cursor-pointer bg-white focus:outline-none
                            "
                            data-action="change->auto-submit#submit"
                          >
                            <option value="" disabled selected>Move to...</option>
                            <% (@groups - [group]).each do |target_group| %>
                              <option value="<%= target_group.id %>"><%= target_group.group_name.presence || "Grp #{target_group.id}" %></option>
                            <% end %>
                          </select>
                        <% end %>

                        <%= button_to "Remove",
                        remove_course_project_group_project_groups_coordinator_actions_path(
                          @course,
                          group,
                          user_id: membership.user_id,
                        ),
                        method: :delete,
                        class: "text-xs text-red-400 hover:text-red-600",
                        data: {
                          turbo_confirm: "Remove #{membership.user.name}?",
                        } %>
                      </div>
                    </li>
                  <% end %>
                </ul>
              </div>

              <%# Admin Force Action %>
              <div
                class="
                  p-2 bg-[#fdfdfd] border-t <%= is_over_limit ? 'border-red-200' : 'border-gray-100' %> flex
                  justify-center
                "
              >
                <%= button_to "Force Confirm",
                force_confirm_course_project_group_path(@course, group),
                method: :patch,
                class:
                  "text-[10px] font-semibold tracking-widest uppercase text-orange-500 hover:text-orange-700 transition-colors py-1" %>
              </div>
            </div>
          <% end %>
        </div>
        <% if @groups.reject(&:confirmed?).empty? %>
          <p class="text-sm text-gray-400 py-2">No draft groups present.</p>
        <% end %>
      </div>

      <%# ================= CONFIRMED GROUPS ================= %>
      <div>
        <h4
          class="
            text-[0.9375em] font-medium tracking-[1px] uppercase text-[#192325] leading-none
            mb-4 pb-2 border-b border-gray-200
          "
        >
          Confirmed Groups
        </h4>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
          <% @groups.select(&:confirmed?).each do |group| %>
            <div
              class="
                border border-[#1F78D1] rounded-[3px] bg-white flex flex-col h-full shadow-sm
              "
            >
              <div class="p-4 flex-1">

                <%# Badges %>
                <div class="flex items-start justify-between mb-3 gap-2">
                  <span
                    class="
                      inline-block bg-[#1F78D1] rounded text-white text-[0.6875rem] font-normal
                      tracking-[1px] leading-none px-[0.625em] py-[0.4375em]
                    "
                  >Confirmed</span>
                  <span class="text-xs text-gray-500">
                    <%= group.project_group_members.size %>
                    /
                    <%= @course.group_max %>
                  </span>
                </div>

                <p class="font-semibold text-base text-[#192325] mb-4">
                  <%= group.group_name.presence || "Unnamed Confirmed Group" %>
                </p>

                <%# Members %>
                <ul class="space-y-3">
                  <% group.project_group_members.each do |membership| %>
                    <li class="flex items-center gap-2 group/member">
                      <div
                        class="
                          inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#1F78D1]/10
                          text-[10px] font-bold text-[#1F78D1] shrink-0
                        "
                      >
                        <%= membership.user.name.presence&.first&.upcase || "?" %>
                      </div>
                      <div class="min-w-0 flex-1">
                        <span class="text-sm text-gray-800 truncate block"><%= membership.user.name.presence || membership.user.email_address %></span>
                        <% if membership.user_id == group.leader_id %>
                          <span class="text-[10px] text-gray-400 uppercase tracking-wide leading-none">(leader)</span>
                        <% end %>
                      </div>

                      <%# Hover Actions %>
                      <div
                        class="
                          opacity-0 group-hover/member:opacity-100 flex items-center gap-3 shrink-0
                          transition-opacity
                        "
                      >
                        <%= form_with url: move_course_project_group_project_groups_coordinator_actions_path(@course, group),
                              method: :post,
                              data: { controller: "auto-submit" },
                              class: "inline" do |f| %>
                          <%= f.hidden_field :user_id, value: membership.user_id %>
                          <select
                            name="target_group_id"
                            class="
                              text-xs border border-gray-300 rounded-[2px] py-0.5 px-1 text-gray-600
                              cursor-pointer bg-white focus:outline-none
                            "
                            data-action="change->auto-submit#submit"
                          >
                            <option value="" disabled selected>Move to...</option>
                            <% (@groups - [group]).each do |target_group| %>
                              <option value="<%= target_group.id %>"><%= target_group.group_name.presence || "Grp #{target_group.id}" %></option>
                            <% end %>
                          </select>
                        <% end %>
                        <%= button_to "Remove",
                        remove_course_project_group_project_groups_coordinator_actions_path(
                          @course,
                          group,
                          user_id: membership.user_id,
                        ),
                        method: :delete,
                        class: "text-xs text-red-400 hover:text-red-600",
                        data: {
                          turbo_confirm: "Remove #{membership.user.name} from confirmed group?",
                        } %>
                      </div>
                    </li>
                  <% end %>
                </ul>
              </div>

              <%# Admin Revert Action %>
              <div class="p-2 bg-[#fdfdfd] border-t border-gray-100 flex justify-center">
                <%= button_to "Revert to Draft",
                revert_course_project_group_path(@course, group),
                method: :patch,
                class:
                  "text-[10px] font-semibold tracking-widest uppercase text-gray-400 hover:text-[#1F78D1] transition-colors py-1" %>
              </div>
            </div>
          <% end %>
        </div>
        <% if @groups.select(&:confirmed?).empty? %>
          <p class="text-sm text-gray-400 py-2">No confirmed groups yet.</p>
        <% end %>
      </div>

    </div>
  </div>
</div>
