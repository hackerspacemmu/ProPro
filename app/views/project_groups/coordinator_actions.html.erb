<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <nav class="text-sm font-medium text-gray-500 mb-6">
    <ol class="list-none p-0 inline-flex">
      <li class="flex items-center">
        <a href="#" class="hover:text-gray-900">Courses</a>
        <svg class="w-3 h-3 mx-3 fill-current" viewBox="0 0 320 512"><path
            d="M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z"
          /></svg>
      </li>
      <li class="flex items-center">
        <span class="text-gray-700"><%= @course.coursecode %>
          -
          <%= @course.course_name %></span>
        <svg class="w-3 h-3 mx-3 fill-current text-gray-500" viewBox="0 0 320 512"><path
            d="M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z"
          /></svg>
      </li>
      <li><span class="text-gray-900 font-bold">Grouping Management</span></li>
    </ol>
  </nav>

  <% unless @course.student_list_finalised? %>
    <div
      class="
        bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8 rounded-r-md flex
        justify-between items-start
      "
    >
      <div class="flex">
        <div class="flex-shrink-0">
          <span class="text-yellow-400 text-xl">⚠️</span>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-yellow-800">Default Mode Active</h3>
          <p class="text-sm text-yellow-700 mt-1">Students cannot self-group. All draft groups must be manually
            confirmed by a coordinator.</p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

    <div class="lg:col-span-1 flex flex-col h-[800px]">
      <div
        class="
          bg-white border border-gray-200 rounded-lg shadow-sm flex flex-col h-full
          overflow-hidden
        "
      >
        <div
          class="
            px-4 py-3 border-b border-gray-200 bg-gray-50 flex justify-between items-center
          "
        >
          <h2 class="font-bold text-gray-800">Ungrouped</h2>
          <span
            class="
              bg-gray-200 text-gray-700 py-0.5 px-2 rounded-full text-xs font-bold
            "
          ><%= @ungrouped_students.count %></span>
        </div>

        <div class="p-3 border-b border-gray-100">
          <input
            type="text"
            placeholder="Search by name..."
            class="
              w-full text-sm border-gray-300 rounded-md shadow-sm focus:ring-blue-500
              focus:border-blue-500
            "
          >
        </div>

        <div class="overflow-y-auto flex-1 p-2">
          <% if @ungrouped_students.empty? %>
            <p class="text-sm text-gray-500 p-4 text-center">All students are currently in a group!</p>
          <% end %>

          <% @ungrouped_students.each do |student| %>
            <div
              class="
                flex justify-between items-center p-2 hover:bg-blue-50 rounded-md group
                transition-colors border-b border-gray-50 last:border-0
              "
            >
              <span class="text-sm font-medium text-gray-700"><%= student.name.presence || student.email %></span>

              <%= form_with url: "#", method: :post,
                    data: {
                      controller: "dynamic-form-action",
                      dynamic_form_action_base_url_value: "/courses/#{@course.id}/project_groups",
                      dynamic_form_action_endpoint_value: "project_groups_coordinator_actions/add"
                    },
                    class: "flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity" do |f| %>

                <%= f.hidden_field :user_id, value: student.id %>

                <select
                  class="
                    text-xs border-gray-300 rounded py-1 pl-2 pr-6 cursor-pointer
                  "
                  data-action="change->dynamic-form-action#update"
                  required
                >
                  <option value="" disabled selected>Select Group</option>
                  <% @groups.each do |g| %>
                    <option value="<%= g.id %>"><%= g.group_name.presence || "Group #{g.id}" %>
                      (<%= g.project_group_members.size %>)</option>
                  <% end %>
                </select>

                <%= f.submit "➕",
                         class:
                           "cursor-pointer text-blue-600 hover:text-blue-800 text-xs font-bold px-2 py-1 border border-blue-200 rounded bg-white shadow-sm" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="lg:col-span-3">

      <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl font-bold text-gray-800">Course Groups (<%= @groups.size %>)</h2>
      </div>

      <h3
        class="
          text-sm font-bold text-gray-400 uppercase tracking-wider mb-4 border-b
          border-gray-200 pb-2
        "
      >Draft Groups (Needs Attention)</h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
        <% @groups.reject(&:confirmed?).each do |group| %>
          <% is_over_limit = group.project_group_members.size > @course.group_max.to_i %>

          <div
            class="
              <%= is_over_limit ? 'bg-red-50 border-red-300' : 'bg-white border-gray-200' %> border rounded-lg shadow-sm
              overflow-hidden flex flex-col
            "
          >
            <div
              class="
                px-4 py-3 border-b <%= is_over_limit ? 'border-red-200 bg-red-100' : 'border-gray-100 bg-gray-50' %> flex justify-between
                items-center
              "
            >
              <div>
                <h4 class="font-bold <%= is_over_limit ? 'text-red-900' : 'text-gray-800' %>"><%= group.group_name.presence || "Draft Group ##{group.id}" %></h4>
              </div>
              <span
                class="
                  <%= is_over_limit ? 'bg-red-200 text-red-900' : 'bg-blue-100 text-blue-800' %> py-1 px-2 rounded font-bold text-xs
                "
              >
                <%= is_over_limit ? "⚠️ " : "" %><%= group.project_group_members.size %>
                /
                <%= @course.group_max %>
              </span>
            </div>

            <div class="p-4 flex-1">
              <ul
                class="
                  text-sm <%= is_over_limit ? 'text-red-800' : 'text-gray-600' %> space-y-2 mb-4
                "
              >
                <% group.project_group_members.each do |member| %>
                  <li class="flex justify-between items-center group/member">
                    <span>
                      <%= member.user_id == group.leader_id ? "👑 " : "" %>
                      <%= member.user.name.presence || member.user.email %>
                    </span>

                    <div class="opacity-0 group-hover/member:opacity-100 flex gap-1 items-center">
                      <%= form_with url: move_course_project_group_project_groups_coordinator_actions_path(@course, group),
                            method: :post,
                            data: { controller: "auto-submit" },
                            class: "inline" do |f| %>

                        <%= f.hidden_field :user_id, value: member.user_id %>

                        <select
                          name="target_group_id"
                          class="
                            text-xs py-0 pl-1 pr-4 rounded border-gray-300 cursor-pointer
                          "
                          data-action="change->auto-submit#submit"
                        >
                          <option value="" disabled selected>↔️ Move</option>
                          <% (@groups - [group]).each do |target_group| %>
                            <option value="<%= target_group.id %>"><%= target_group.group_name.presence || "Grp #{target_group.id}" %></option>
                          <% end %>
                        </select>
                      <% end %>

                      <%= button_to "🗑️",
                      remove_course_project_group_project_groups_coordinator_actions_path(
                        @course,
                        group,
                        user_id: member.user_id,
                      ),
                      method: :delete,
                      form_class: "inline",
                      class: "text-gray-400 hover:text-red-600 ml-1 px-1",
                      data: {
                        turbo_confirm: "Remove #{member.user.name.presence || "user"} from group?",
                      } %>
                    </div>
                  </li>
                <% end %>
              </ul>
            </div>

            <div
              class="
                px-4 py-3 <%= is_over_limit ? 'bg-red-100 border-t border-red-200' : 'bg-gray-50 border-t border-gray-100' %> text-center
              "
            >
              <%= button_to "⚡ Force Confirm",
              force_confirm_course_project_group_path(@course, group),
              method: :patch,
              class:
                "w-full bg-orange-100 hover:bg-orange-200 text-orange-800 text-sm font-bold py-2 rounded transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>

      <h3
        class="
          text-sm font-bold text-gray-400 uppercase tracking-wider mb-4 border-b
          border-gray-200 pb-2
        "
      >Confirmed Groups (Locked In)</h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @groups.select(&:confirmed?).each do |group| %>
          <div
            class="
              bg-white border-2 border-green-200 rounded-lg shadow-sm overflow-hidden flex
              flex-col
            "
          >
            <div
              class="
                px-4 py-3 border-b border-green-100 bg-green-50 flex justify-between
                items-center
              "
            >
              <h4 class="font-bold text-green-900 text-lg"><%= group.group_name.presence || "Group ##{group.id}" %></h4>
              <span class="bg-green-200 text-green-900 py-1 px-2 rounded font-bold text-xs"><%= group.project_group_members.size %>
                /
                <%= @course.group_max %></span>
            </div>

            <div class="p-4 flex-1">
              <ul class="text-sm text-gray-600 space-y-2 mb-4">
                <% group.project_group_members.each do |member| %>
                  <li class="flex justify-between items-center group/member">
                    <span>
                      <%= member.user_id == group.leader_id ? "👑 " : "" %>
                      <%= member.user.name.presence || member.user.email %>
                    </span>

                    <div class="opacity-0 group-hover/member:opacity-100 flex gap-1 items-center">
                      <%= form_with url: move_course_project_group_project_groups_coordinator_actions_path(@course, group),
                            method: :post,
                            data: { controller: "auto-submit" },
                            class: "inline" do |f| %>

                        <%= f.hidden_field :user_id, value: member.user_id %>

                        <select
                          name="target_group_id"
                          class="
                            text-xs py-0 pl-1 pr-4 rounded border-gray-300 cursor-pointer
                          "
                          data-action="change->auto-submit#submit"
                        >
                          <option value="" disabled selected>↔️ Move</option>
                          <% (@groups - [group]).each do |target_group| %>
                            <option value="<%= target_group.id %>"><%= target_group.group_name.presence || "Grp #{target_group.id}" %></option>
                          <% end %>
                        </select>
                      <% end %>

                      <%= button_to "🗑️",
                      remove_course_project_group_project_groups_coordinator_actions_path(
                        @course,
                        group,
                        user_id: member.user_id,
                      ),
                      method: :delete,
                      form_class: "inline",
                      class: "text-gray-400 hover:text-red-600 ml-1 px-1",
                      data: {
                        turbo_confirm:
                          "Remove #{member.user.name.presence || "user"} from confirmed group?",
                      } %>
                    </div>
                  </li>
                <% end %>
              </ul>
            </div>

            <div class="px-4 py-2 border-t border-gray-100 text-center bg-gray-50">
              <%= button_to "↩️ Revert to Draft",
              revert_course_project_group_path(@course, group),
              method: :patch,
              class:
                "text-gray-500 hover:text-gray-800 text-xs font-medium py-1 transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>
