<%# Hide entirely for coordinators / lecturers %>
<% unless @current_user_enrolment&.coordinator? || @current_user_enrolment&.lecturer? %>

  <% if @my_group.nil? %>

  <%
    window_open = @course.grouping_window_open?
  %>

  <div class="border-2 border-dashed border-gray-300 rounded-[3px] bg-white mb-6"
      data-testid="my-group-panel-ungrouped">

    <%# ── Header ── %>
    <div class="flex items-center gap-3 px-5 py-4 border-b border-gray-200">
      <div class="w-7 h-7 rounded-full bg-gray-200 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" height="16px" viewBox="0 -960 960 960"
            width="16px" fill="#9ca3af" aria-hidden="true">
          <path d="M40-160v-112q0-34 17.5-62.5T104-378q62-31 126-46.5T360-440q66 0 130 15.5T616-378q29 15 46.5 43.5T680-272v112H40Zm720 0v-120q0-44-24.5-84.5T666-434q51 6 96 20.5t84 35.5q36 20 55 44.5t19 53.5v120H760ZM360-480q-66 0-113-47t-47-113q0-66 47-113t113-47q66 0 113 47t47 113q0 66-47 113t-113 47Zm400-160q0 66-47 113t-113 47q-11 0-28-2.5t-28-5.5q27-32 41.5-71t14.5-81q0-42-14.5-81T544-792q14-5 28-6.5t28-1.5q66 0 113 47t47 113Z"/>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-900">No group yet</h2>
        <p class="text-xs text-gray-400 mt-0.5">
          You're not in a group. Create one or request to join an existing group.
        </p>
      </div>
    </div>

    <%# ── Three columns — mirrors STATE B skeleton ── %>
    <div class="block md:flex divide-y md:divide-y-0 md:divide-x divide-gray-200">

      <%# ── Col 1: Create ── %>
      <div class="w-full md:w-48 shrink-0 p-4">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">Create</p>

        <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" height="18px" viewBox="0 -960 960 960"
              width="18px" fill="#1F78D1" aria-hidden="true">
            <path d="M440-280h80v-160h160v-80H520v-160h-80v160H280v80h160v160Zm40 200q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/>
          </svg>
        </div>

        <p class="text-sm font-medium text-gray-900 mb-1">Start a group</p>
        <p class="text-xs text-gray-500 leading-relaxed mb-3">
          Create a draft group. Others can find and request to join you.
        </p>

        <% if window_open %>
          <%# Student create — no modal needed, current_user becomes leader %>
          <%= button_to course_project_groups_path(@course),
                method: :post,
                class: "inline-flex items-center gap-1 text-xs px-3 py-1.5 bg-[#1F78D1] text-white rounded-[3px] hover:bg-[#1a6abf] transition-colors font-medium" do %>
            New group
            <svg xmlns="http://www.w3.org/2000/svg" height="12px" viewBox="0 -960 960 960"
                width="12px" fill="currentColor" aria-hidden="true">
              <path d="M647-440H160v-80h487L423-744l57-56 320 320-320 320-57-56 224-224Z"/>
            </svg>
          <% end %>
        <% else %>
          <span class="text-xs text-gray-300 font-medium">Grouping window closed</span>
        <% end %>
      </div>

      <%# ── Col 2: Join ── %>
      <div class="flex-1 min-w-0 p-4">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">Join</p>

        <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" height="18px" viewBox="0 -960 960 960"
              width="18px" fill="#475D65" aria-hidden="true">
            <path d="M480-120v-80h280v-560H480v-80h280q33 0 56.5 23.5T840-760v560q0 33-23.5 56.5T760-120H480Zm-80-160-55-58 102-102H120v-80h327L345-622l55-58 200 200-200 200Z"/>
          </svg>
        </div>

        <p class="text-sm font-medium text-gray-900 mb-1">Request to join a group</p>
        <p class="text-xs text-gray-500 leading-relaxed mb-3">
          Browse draft groups below and send a join request. The group leader will approve or decline.
        </p>

        <% if window_open %>
          <a href="#result-pane"
            class="inline-flex items-center gap-1 text-xs px-3 py-1.5 border border-gray-300 rounded-[3px] text-gray-600 hover:border-gray-400 hover:text-gray-800 transition-colors font-medium">
            Browse groups
            <svg xmlns="http://www.w3.org/2000/svg" height="12px" viewBox="0 -960 960 960"
                width="12px" fill="currentColor" aria-hidden="true">
              <path d="M480-344 240-584l57-56 183 183 183-183 57 56-240 240Z"/>
            </svg>
          </a>
        <% else %>
          <span class="text-xs text-gray-300 font-medium">Grouping window closed</span>
        <% end %>
      </div>

      <%# ── Col 3: Pending requests sent by this student ── %>
      <div class="w-full md:w-[200px] shrink-0 p-4">
        <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">
          Pending requests
        </p>

        <% if @my_pending_requests&.any? %>
          <ul class="space-y-0 divide-y divide-gray-100">
            <% @my_pending_requests.each do |invite| %>
              <li class="flex items-center gap-2 py-2 first:pt-0">
                <div class="w-6 h-6 rounded-full bg-gray-200 flex items-center justify-center
                            text-[9px] font-bold text-gray-600 shrink-0">
                  <%= invite.project_group.group_name.first(2).upcase %>
                </div>
                <span class="text-xs text-gray-800 font-medium flex-1 min-w-0 truncate">
                  <%= invite.project_group.group_name %>
                </span>
                <span class="text-[9px] font-semibold uppercase tracking-wide
                            bg-gray-100 text-gray-400 rounded-[3px] px-1.5 py-0.5 shrink-0">
                  Sent
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="flex flex-col items-center justify-center py-6 gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960"
                width="20px" fill="#e5e7eb" aria-hidden="true">
              <path d="M160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h640q33 0 56.5 23.5T880-720v480q0 33-23.5 56.5T800-160H160Zm320-280L160-640v400h640v-400L480-440Zm0-80 320-200H160l320 200ZM160-640v-80 480-400Z"/>
            </svg>
            <p class="text-xs text-gray-400 text-center">No pending requests</p>
          </div>
        <% end %>
      </div>

    </div>
  </div>

  <% else %>
    <%# ── STATE B: In a group ── %>
    <%
      am_leader    = @my_group.leader_id == current_user.id
      is_confirmed = @my_group.confirmed?
      is_locked    = @my_group.locked?
      member_count = @my_group.project_group_members.size
      can_confirm  = @my_group.can_confirm?
      window_open  = @course.grouping_window_open?
    %>

    <div class="border-2 border-gray-300 rounded-[3px] bg-white mb-6" data-testid="my-group-panel-grouped">

      <%# ── Full width header %>
      <div class="flex items-start justify-between px-5 py-4 border-b border-gray-200">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <div class="w-7 h-7 rounded-full bg-gray-200 shrink-0"></div>
            <h2 class="text-xl font-bold text-gray-900"><%= @my_group.group_name %></h2>

            <% if is_confirmed %>
              <span class="inline-block bg-[#1F78D1] text-white text-[0.6875rem] font-normal rounded tracking-[1px] leading-none px-[0.625em] py-[0.4375em] whitespace-nowrap">
                Confirmed
              </span>
            <% else %>
              <span class="inline-block bg-[#475D65] text-white text-[0.6875rem] font-normal rounded tracking-[1px] leading-none px-[0.625em] py-[0.4375em] whitespace-nowrap">
                Draft
              </span>
            <% end %>

            <% if is_locked %>
              <span class="inline-block">
                <svg xmlns="http://www.w3.org/2000/svg" height="16px" viewBox="0 -960 960 960" width="16px" fill="currentColor" class="inline-block align-middle">
                  <path d="M240-80q-33 0-56.5-23.5T160-160v-400q0-33 23.5-56.5T240-640h40v-80q0-83 58.5-141.5T480-920q83 0 141.5 58.5T680-720v80h40q33 0 56.5 23.5T800-560v400q0 33-23.5 56.5T720-80H240Zm0-80h480v-400H240v400Zm296.5-143.5Q560-327 560-360t-23.5-56.5Q513-440 480-440t-56.5 23.5Q400-393 400-360t23.5 56.5Q447-280 480-280t56.5-23.5ZM360-640h240v-80q0-50-35-85t-85-35q-50 0-85 35t-35 85v80ZM240-160v-400 400Z"/>
                </svg>
              </span>
            <% end %>
          </div>
          <p class="text-xs text-gray-400"><%= member_count %> / <%= @course.group_max %> members</p>
        </div>

        <%# Dissolve — leader only, draft only %>
        <% if am_leader && !is_confirmed && window_open %>
          <%= button_to "Dissolve group",
                course_project_group_path(@course, @my_group),
                method: :delete,
                class: "text-xs font-medium text-red-500 border border-red-200 rounded px-2.5 py-1 hover:bg-red-50 transition-colors shrink-0 mt-1",
                form: { data: { confirm: "Dissolve this group? This cannot be undone." } } %>
        <% end %>
      </div>

      <%# ── Three columns %>
      <div class="block md:flex divide-y md:divide-y-0 md:divide-x divide-gray-200">

        <%# ── Col 1: Settings %>
        <div class="w-full md:w-48 shrink-0 p-4">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">Settings</p>

          <div class="flex flex-col gap-1.5">
            <% if am_leader && !is_confirmed && window_open %>
              <%= button_to "Confirm Group",
                    confirm_course_project_group_path(@course, @my_group),
                    method: :patch,
                    disabled: !can_confirm,
                    class: "w-full px-3 py-1.5 text-xs font-semibold text-white bg-[#1F78D1] rounded-[3px] hover:bg-[#1a6abf] transition-colors text-left disabled:opacity-40 disabled:cursor-not-allowed",
                    title: can_confirm ? nil : "Group needs #{@course.group_min}–#{@course.group_max} members to confirm" %>
            <% end %>

            <% if am_leader && is_confirmed && window_open %>
              <%= button_to "Revert to Draft",
                    revert_course_project_group_path(@course, @my_group),
                    method: :patch,
                    class: "w-full px-3 py-1.5 text-xs font-medium text-gray-600 border border-gray-300 rounded-[3px] hover:border-gray-400 hover:text-gray-800 transition-colors text-left",
                    form: { data: { confirm: "Revert to draft? You will lose confirmed status." } } %>
            <% end %>

            <% if am_leader && !is_confirmed && window_open %>
              <% if is_locked %>
                <%= button_to "Unlock Group",
                      unlock_course_project_group_path(@course, @my_group),
                      method: :patch,
                      class: "w-full px-3 py-1.5 text-xs font-medium text-gray-600 border border-gray-300 rounded-[3px] hover:border-gray-400 hover:text-gray-800 transition-colors text-left" %>
              <% else %>
                <%= button_to "Lock Group",
                      lock_course_project_group_path(@course, @my_group),
                      method: :patch,
                      class: "w-full px-3 py-1.5 text-xs font-medium text-gray-600 border border-gray-300 rounded-[3px] hover:border-gray-400 hover:text-gray-800 transition-colors text-left" %>
              <% end %>
            <% end %>
          </div>

          <div class="mt-4 pt-3 border-t border-gray-100">
            <%# Leave group — Person 2 %>
            <button disabled class="text-xs text-gray-400 hover:text-gray-600 transition-colors opacity-40 cursor-not-allowed">
              Leave group
            </button>
          </div>
        </div>

        <%# ── Col 2: Members %>
        <div class="flex-1 min-w-0 p-4">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">Members</p>
          <ul class="space-y-0 divide-y divide-gray-100">
            <% @my_group.project_group_members.each do |membership| %>
              <% member = membership.user %>
              <% is_this_leader = member.id == @my_group.leader_id %>

              <li class="flex items-center justify-between py-2 first:pt-0" data-testid="member-row-<%= member.id %>">
                <div class="flex items-center gap-2.5">
                  <div class="w-6 h-6 rounded-full bg-gray-200 shrink-0"></div>
                  <span class="text-sm text-gray-800"><%= member.name %></span>
                  <% if is_this_leader %>
                    <span class="text-xs text-gray-400">(leader)</span>
                  <% end %>
                </div>

                <% if am_leader && !is_this_leader && !is_confirmed && window_open %>
                  <div class="flex items-center gap-3 shrink-0">
                    <%= button_to promote_leader_course_project_group_path(@course, @my_group),
                          method: :patch,
                          params: { user_id: member.id },
                          class: "text-xs text-gray-400 hover:text-gray-600 transition-colors",
                          form: { data: { confirm: "Make #{member.name} the group leader? You will lose leader privileges." } } do %>
                      Promote
                    <% end %>

                    <%= button_to course_project_group_member_path(@course, @my_group, member),
                          method: :delete,
                          class: "text-xs text-red-400 hover:text-red-600 transition-colors",
                          form: { data: { confirm: "Remove #{member.name} from the group?" } } do %>
                      Kick
                    <% end %>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>

        <%# ── Col 3: Join Requests — Person 3 wires this %>
        <div class="w-full md:w-80 shrink-0 p-4">
          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">
            Join Requests
          </p>
          <p class="text-xs text-gray-400">No pending requests</p>
        </div>

      </div>
    </div>

  <% end %>

<% end %>