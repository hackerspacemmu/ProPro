<% content_for :hide_breadcrumbs, true %>
<% content_for :hide_toggler, true %>
<main
  class="
    grid min-h-[80vh] place-items-center bg-white px-6 py-24 sm:py-32 lg:px-8
  "
>
  <div class="text-center">
    <%# The Error Code %>
    <p class="text-base font-semibold text-blue-600">500</p>

    <%# The Main Heading %>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      Internal Server Error
    </h1>

    <%# The Subtext %>
    <p class="mt-6 text-base leading-7 text-gray-600">
      Sorry, we couldn't find the page you're looking for. It might have been
      moved or deleted.
    </p>

    <%# Action Buttons %>
    <div class="mt-10 flex items-center justify-center gap-x-6">

      <%= link_to "Go back home",
      root_path,
      class:
        "rounded-md bg-blue-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-colors duration-200" %>

      <%# Secondary Link: Optional, route to a help desk or contact page %>
      <a
        href="#"
        class="
          text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors
          duration-200
        "
      >
        Contact support
        <span aria-hidden="true">&rarr;</span>
      </a>

    </div>
  </div>
</main>
