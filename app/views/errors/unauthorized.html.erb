<% content_for :hide_breadcrumbs, true %>
<% content_for :hide_toggler, true %>
<% provide :no_footer, true %>
<main
  class="
    grid min-h-[calc(100vh-70px)] place-items-center bg-white px-6 py-10 sm:py-20
    lg:px-8
  "
>
  <div class="text-center">
    <p class="text-3xl font-bold text-red-600">401</p>

    <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      Unauthorized
    </h1>

    <p class="mt-6 text-base leading-7 text-gray-600">
      You need to be authenticated to access this page. Please login to
      continue.
    </p>

    <div class="mt-10 flex items-center justify-center gap-x-6">

      <%= link_to "Go to Login",
      login_path,
      class:
        "rounded-md bg-blue-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-colors duration-200" %>

    </div>
  </div>
</main>
