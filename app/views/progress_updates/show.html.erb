<% breadcrumb :progress_update, @progress_update %>
<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "tailwind", "new_tailwind" %>
<% end %>
<% content_for :title,
"Progress Update - #{@project.current_title.truncate(TITLE_NAME_LIMIT)} | ProPro" %>

<main class="bg-gray-50 w-full pt-6 pb-16 px-4 md:px-8">
  <div class="max-w-4xl mx-auto w-full">

    <%# --- Header --- %>
    <div class="mb-8">
      <%= link_to course_project_path(@course, @project, tab: "progress", anchor: "project-progress"), class: "group inline-flex items-center text-sm font-medium text-gray-500 hover:text-blue-600 transition-colors mb-6" do %>
        <div
          class="
            w-8 h-8 rounded-full bg-white border border-gray-200 flex items-center
            justify-center mr-2 group-hover:border-blue-300 shadow-sm transition-all
          "
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            /></svg>
        </div>
        Back to Project
      <% end %>

      <h1
        class="
          text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight flex
          items-center gap-3
        "
      >
        Progress Update
      </h1>
      <p class="text-gray-500 mt-2 text-base">
        View details for
        <strong><%= @current_instance.title %></strong>
      </p>
    </div>

    <%# --- Main Content Card --- %>
    <div
      class="
        bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden
      "
    >

      <%# Update Metadata %>
      <div
        class="
          bg-gray-50/50 border-b border-gray-100 p-6 md:px-8 flex flex-col sm:flex-row
          sm:items-center justify-between gap-4
        "
      >

        <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6">
          <div class="flex items-center gap-2">
            <span class="text-sm font-semibold text-gray-700">Date:</span>
            <span
              class="
                text-sm text-gray-900 bg-white px-2.5 py-1 rounded-md border border-gray-200
                shadow-sm
              "
            ><%= @progress_update.date %></span>
          </div>

          <div class="flex items-center gap-2">
            <span class="text-sm font-semibold text-gray-700">Rating:</span>
            <% rating_color =
              case @progress_update.rating
              when "excellent"
                "bg-emerald-100 text-emerald-800 border-emerald-200"
              when "good"
                "bg-blue-100 text-blue-800 border-blue-200"
              when "needs_improvement"
                "bg-orange-100 text-orange-800 border-orange-200"
              when "poor"
                "bg-red-100 text-red-800 border-red-200"
              else
                "bg-gray-100 text-gray-800 border-gray-200"
              end %>
            <span
              class="
                text-xs font-bold px-2.5 py-1 rounded-full border
                <%= rating_color %>
              "
            ><%= @progress_update.rating.gsub("_", " ").titleize %></span>
          </div>
        </div>

      </div>

      <%# Feedback Content %>
      <div class="p-6 md:p-8">
        <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Feedback</h3>
        <div
          class="
            prose prose-slate max-w-none text-gray-800 bg-gray-50/50 p-5 rounded-xl border
            border-gray-100 leading-relaxed text-[15px]
          "
        >
          <%= h(@progress_update.feedback).gsub("\n", "<br/>").html_safe %>
        </div>
      </div>

      <%# --- Action Buttons --- %>
      <% if @current_instance.supervisor == current_user %>
        <div
          class="
            p-6 md:px-8 border-t border-gray-100 bg-gray-50/30 flex flex-col-reverse
            sm:flex-row items-center justify-center sm:justify-end gap-3
          "
        >

          <%= button_to course_project_progress_update_path(@course, @project, @progress_update),
                method: :delete,
                data: { turbo_confirm: "Are you sure you want to delete this progress update?" },
                class: "flex items-center justify-center w-full sm:w-auto gap-2 px-4 py-2 text-sm font-bold text-red-600 bg-red-50 hover:bg-red-100 hover:text-red-700 border border-red-100 rounded-lg transition-colors cursor-pointer" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
              /></svg>
            Delete
          <% end %>

          <%= link_to edit_course_project_progress_update_path(@course, @project, @progress_update),
                class: "flex items-center justify-center w-full sm:w-auto gap-2 px-5 py-2 text-sm font-bold text-white bg-slate-700 hover:bg-slate-800 rounded-lg shadow-sm transition-all transform active:scale-95" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              /></svg>
            Edit Update
          <% end %>

        </div>
      <% end %>

    </div>
  </div>
</main>
