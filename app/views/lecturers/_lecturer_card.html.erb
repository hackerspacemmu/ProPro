<% breadcrumb :lecturers, @course %>
<%# --- Disables footer --- %>
<% content_for :no_footer, true %>

<div
  class="
    w-full px-4 sm:px-6 md:px-8 py-6
  "
>

  <div class="mx-auto w-full max-w-6xl">

    <ul
      class="
        list-none p-0 m-0
        grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3
        gap-4
      "
    >
      <% @lecturers.each do |lecturer| %>
        <% capacity_info = @lecturer_capacity_info[lecturer.id] %>
        <% capacity_text_color =
          capacity_info[:is_at_capacity] ? "text-red-500" : "text-black" %>

        <li>
          <%= link_to(
                course_lecturer_path(@course, lecturer, from_new_project: params[:from_new_project]),
                class: "
                  flex flex-col gap-3 p-5 bg-white border border-gray-200 rounded-xl
                  hover:border-gray-300 hover:shadow-sm
                  transition-all
                "
              ) do %>

            <div
              class="
                w-10 h-10 bg-[#d9d9d9] rounded-full shrink-0
                flex justify-center items-center
                text-base text-gray-700 font-medium
              "
            >
              <%= lecturer.name.first.upcase %>
            </div>

            <div class="flex-1 min-w-0">

              <div class="flex items-center gap-4 mb-1">
                <div class="text-gray-800 text-base font-semibold truncate">
                  <%= lecturer.name %>
                </div>

                <span
                  class="
                    ml-auto whitespace-nowrap text-sm font-medium
                    <%= capacity_text_color %>
                  "
                >
                  <%= capacity_info[:approved_proposals] %>/<%= capacity_info[:max_capacity] %>

                  <% if capacity_info[:pending_proposals] > 0 %>
                    <span class="text-xs text-amber-600 ml-1">
                      (<%= capacity_info[:pending_proposals] %> pending)
                    </span>
                  <% end %>
                </span>
              </div>

              <div class="text-xs text-gray-500">
                Statistics coming soon...
              </div>

            </div>

          <% end %>
        </li>
      <% end %>
    </ul>

  </div>
</div>
