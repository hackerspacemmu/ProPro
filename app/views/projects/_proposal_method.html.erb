<%# locals: (course:, selected_lecturer:, selected_topic:, lecturer_capacity_info:, selected_own_proposal_lecturer_id: nil, project: nil, readonly: false) %>

<% lecturer_selected = selected_lecturer.present? %>
<% topic_selected = selected_topic.present? %>
<% editing = project.present? %>

<div class="border border-gray-200 rounded-2xl bg-white p-6 space-y-6 <%= 'opacity-50 pointer-events-none' if readonly %>">

  <%if @course.solo_supervisor? %>  
    <% solo_id = course.enrolments.find_by(role: [:lecturer, :coordinator])&.id %>
  <% end %>
  <%= hidden_field_tag :based_on_topic,
  (selected_topic&.id || 
  (selected_own_proposal_lecturer_id.present? ? "own_proposal_#{selected_own_proposal_lecturer_id}" : 
  (@course.solo_supervisor? ? "own_proposal_#{solo_id}" : ""))) %>

  <label class="block text-xs sm:text-sm font-bold text-gray-700 uppercase tracking-wide mb-3">
    PROPOSAL METHOD
  </label>
  <p class="text-xs text-gray-500 mb-3">
    Choose <span class="font-semibold">one</span> option below to <%= editing ? "update" : "start" %> your proposal.
  </p>

  <%# Lecturer panel %>
  <div id="lecturer-panel"
      class="border border-gray-200 rounded-xl bg-gray-50 p-5 space-y-4 <%= 'opacity-50 pointer-events-none' if topic_selected %>">

    <div class="flex flex-wrap items-start justify-between gap-3">
      <div class="flex items-start gap-3 min-w-0">
        <div class="w-9 h-9 bg-white border border-gray-200 rounded-lg flex items-center justify-center shrink-0 shadow-sm">
          <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-sm font-bold text-gray-800">Lecturer</p>
          <% if selected_lecturer %>
            <p class="text-xs text-gray-500">This lecturer has been pre-selected below.</p>
          <% else %>
            <p class="text-xs text-gray-500">
              <span class="font-bold text-red-600">Warning:</span>
              Selecting a lecturer will overwrite any details already filled in.
            </p>
          <% end %>
        </div>
      </div>

      <% if @course.solo_supervisor? %>
        <% selected_lecturer = course.enrolments.find_by(role: :coordinator).user %>
      <% end %>

      <% if selected_lecturer %>
        <% unselect_lecturer_path = editing ? edit_course_project_path(course, project, clear_lecturer: true) : new_course_project_path(course) %>
        <% change_lecturer_path = editing ? course_lecturers_path(course, from_edit_project: true, project_id: project.id) : course_lecturers_path(course, from_new_project: true) %>
        <div class="flex flex-wrap items-center gap-2">
          <%= link_to unselect_lecturer_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 sm:px-4 sm:py-2 text-xs font-semibold text-red-600 bg-white border border-red-200 rounded-lg hover:bg-red-50 hover:border-red-300 transition-colors shadow-sm" do %>
            Unselect lecturer
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          <% end %>
          <%= link_to change_lecturer_path,
              onclick: "return confirm('You\\'ll lose your current form data. Continue?');",
              class: "inline-flex items-center gap-1.5 px-3 py-1.5 sm:px-4 sm:py-2 text-xs font-semibold text-gray-700 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors shadow-sm" do %>
            Change lecturer
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          <% end %>
        </div>
      <% else %>
        <% view_lecturers_path = editing ? course_lecturers_path(course, from_edit_project: true, project_id: project.id) : course_lecturers_path(course, from_new_project: true) %>
        <%= link_to view_lecturers_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 sm:px-4 sm:py-2 text-xs font-semibold text-gray-700 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors shadow-sm" do %>
          View all lecturers
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        <% end %>
      <% end %>
    </div>

    <% if selected_lecturer %>
      <% capacity_info = lecturer_capacity_info[selected_lecturer.id] %>
      <div class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-6 w-full">
        <div class="border border-gray-200 rounded-xl bg-white p-5 shadow-sm">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-[#d9d9d9] rounded-full flex items-center justify-center text-base font-semibold text-gray-700 shrink-0">
              <%= selected_lecturer.name.first.upcase %>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-base font-semibold text-gray-900 truncate"><%= selected_lecturer.name %></p>
              <p class="text-sm text-gray-500">
                <%= capacity_info[:approved_proposals] %>/<%= capacity_info[:max_capacity] %> approved
                <% if capacity_info[:pending_proposals] > 0 %>
                  <span class="text-amber-600 ml-1">· <%= capacity_info[:pending_proposals] %> pending</span>
                <% end %>
              </p>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  
  <% if @course.toggle_topics && !@course.solo_supervisor? %>
    <%# OR divider %>
    <div class="flex items-center justify-center my-4">
      <div class="w-8 h-8 rounded-full bg-gray-100 border border-gray-200 flex items-center justify-center">
        <span class="text-xs font-medium text-gray-400">or</span>
      </div>
    </div>
  <% end %>

  <% if @course.toggle_topics %>
    <%# Topic panel %>
    <div id="topic-panel"
        class="border border-gray-200 rounded-xl bg-gray-50 p-5 space-y-4 <%= 'opacity-50 pointer-events-none' if lecturer_selected %>">

      <div class="flex flex-wrap items-start justify-between gap-3">
        <div class="flex items-start gap-3 min-w-0">
          <div class="w-9 h-9 bg-white border border-gray-200 rounded-lg flex items-center justify-center shrink-0 shadow-sm">
            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-bold text-gray-800">Topic</p>
            <% if selected_topic %>
              <p class="text-xs text-gray-500">This topic and its details have been pre-filled below.</p>
            <% else %>
              <p class="text-xs text-gray-500">
                <span class="font-bold text-red-600">Warning:</span>
                Selecting a topic will overwrite any details already filled in.
              </p>
            <% end %>
          </div>
        </div>

        <% if selected_topic %>
          <% unselect_topic_path = editing ? edit_course_project_path(course, project, clear_topic: true) : new_course_project_path(course) %>
          <% change_topic_path = editing ? course_topics_path(course, from_edit_project: true, project_id: project.id) : course_topics_path(course, from_new_project: true) %>
          <div class="flex flex-wrap items-center gap-2">
            <%= link_to unselect_topic_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 sm:px-4 sm:py-2 text-xs font-semibold text-red-600 bg-white border border-red-200 rounded-lg hover:bg-red-50 hover:border-red-300 transition-colors shadow-sm" do %>
              Unselect topic
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
            <%= link_to change_topic_path,
                onclick: "return confirm('You\\'ll lose your current form data. Continue?');",
                class: "inline-flex items-center gap-1.5 px-3 py-1.5 sm:px-4 sm:py-2 text-xs font-semibold text-gray-700 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors shadow-sm" do %>
              Change topic
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            <% end %>
          </div>
        <% else %>
          <% view_topics_path = editing ? course_topics_path(course, from_edit_project: true, project_id: project.id) : course_topics_path(course, from_new_project: true) %>
          <%= link_to view_topics_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 sm:px-4 sm:py-2 text-xs font-semibold text-gray-700 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors shadow-sm" do %>
            View all topics
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          <% end %>
        <% end %>
      </div>

      <% if selected_topic %>
        <div class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(350px,1fr))] gap-6 w-full">
          <%= render "courses/topic_card", topic: selected_topic %>
        </div>
      <% end %>
    </div>
  <% end %>

</div>