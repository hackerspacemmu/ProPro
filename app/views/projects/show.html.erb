<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "tailwind", "new_tailwind" %>
<% end %>

<% content_for :hide_toggler, true %>

<% breadcrumb :project, @project %>

<% content_for :title do %>
  <%= @project.current_title.truncate(TITLE_NAME_LIMIT) %>
  - View
  <%= @project.current_instance.approved? ? "Project" : "Proposal" %>
  | ProPro
<% end %>

<main class="min-h-screen bg-gray-50 w-full pt-[1em] pb-6">
  <div class="max-w-[1920px] mx-auto w-full px-4 md:px-12 min-[1245px]:px-16">

    <div class="flex items-center justify-start mb-2">
      <%= link_to course_path(@course), class: "group flex items-center text-sm font-medium text-gray-500 hover:text-green-600 transition-colors" do %>
        <div
          class="
            w-8 h-8 rounded-full bg-white border border-gray-200 flex items-center
            justify-center mr-2 group-hover:border-green-300 shadow-sm transition-all
          "
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            /></svg>
        </div>
        Back to Course
      <% end %>
    </div>

    <div data-controller="mobile-tabs" class="w-full">
      <div
        class="
          flex flex-col min-[1245px]:flex-row gap-0 md:gap-4 min-[1245px]:gap-8
          items-start justify-center
        "
      >

        <div
          class="
            flex-1 w-full min-w-0 space-y-6 min-[1245px]:space-y-8 order-1
            min-[1245px]:order-1
          "
        >

          <%= render "project_header",
          current_instance: @current_instance,
          owner: @owner,
          project: @project,
          members: @members,
          current_version: @current_version,
          latest_version: @latest_version,
          course: @course,
          instances: @instances %>

          <%# -- MOBILE/TABLET PROJECT ACTIONS (Above tabs, max width restricted) -- %>
          <% if policy(@project).update? && !current_user.is_staff || @current_version != @latest_version %>
            <section
              class="
                min-[1245px]:hidden bg-white rounded-2xl shadow-sm border border-gray-100 p-5
                w-full sm:max-w-[450px] sm:mx-auto min-[1245px]:mx-0
              "
            >
              <h4
                class="
                  text-xs font-bold text-gray-400 uppercase tracking-wider mb-4 flex items-center
                  gap-2
                "
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 10V3L4 14h7v7l9-11h-7z"
                  /></svg>
                Actions
              </h4>
              <%= render "project_actions",
              members: @members,
              current_user: current_user,
              project: @project,
              current_version: @current_version,
              latest_version: @latest_version,
              course: @course %>
            </section>
          <% end %>

          <%# -- MOBILE TOP-LEVEL TABS (Stimulus controlled, Hidden on Desktop) -- %>
          <div
            class="
              flex bg-white rounded-xl min-[1245px]:hidden shadow-sm border border-gray-100
              p-1
            "
          >
            <button
              data-mobile-tabs-target="btn"
              data-action="click->mobile-tabs#switchTab"
              data-panel="details"
              class="
                flex-1 py-2.5 text-sm font-semibold sm:font-bold text-center rounded-lg
                bg-slate-700 text-white shadow-sm transition-all
              "
            >
              Details
            </button>

            <% if @course.use_progress_updates %>
              <button
                data-mobile-tabs-target="btn"
                data-action="click->mobile-tabs#switchTab"
                data-panel="progress"
                class="
                  flex-1 py-2.5 text-sm font-semibold sm:font-bold text-center rounded-lg
                  text-gray-500 hover:text-slate-700 transition-all
                "
              >
                Progress Updates
              </button>
            <% end %>

            <button
              data-mobile-tabs-target="btn"
              data-action="click->mobile-tabs#switchTab"
              data-panel="comments"
              class="
                flex-1 py-2.5 text-sm font-semibold sm:font-bold text-center rounded-lg
                text-gray-500 hover:text-slate-700 transition-all
              "
            >
              Comments (<%= @comments.count %>)
            </button>
          </div>

          <%# -- DETAILS PANEL -- %>
          <div
            data-mobile-tabs-target="detailsPanel"
            class="block min-[1245px]:block space-y-8"
          >

            <%# Mobile-only Details (bypasses _project_fields so blue tabs don't show) %>
            <div class="min-[1245px]:hidden">
              <%= render "project_details",
              fields: @current_fields,
              next_fields: @next_fields,
              based_on_topic_name:
                @current_instance&.source_topic&.topic_instances&.last&.title || nil,
              index: @index,
              instances: @instances %>
            </div>

            <%# Desktop-only Fields (restores the original Blue Tabs Turbo handling) %>
            <div class="hidden min-[1245px]:block">
              <%= render "project_fields",
              project: @project,
              progress: @progress,
              fields: @current_fields,
              next_fields: @next_fields,
              based_on_topic_name:
                @current_instance&.source_topic&.topic_instances&.last&.title || nil,
              index: @index,
              instances: @instances,
              progress_updates: @progress_updates,
              current_version: @current_version,
              latest_version: @latest_version,
              weeks: @weeks,
              course: @course %>
            </div>

          </div>

          <%# -- PROGRESS PANEL (Mobile Only) -- %>
          <div
            data-mobile-tabs-target="progressPanel"
            class="hidden min-[1245px]:hidden space-y-8"
          >
            <%# -- MOBILE-ONLY PROGRESS UPDATE CARD -- %>
            <% if policy(@project).can_record_progress_update? && @current_version == @latest_version %>
              <div
                class="
                  bg-gray-50 rounded-2xl p-6 border border-blue-100 shadow-sm relative
                  overflow-hidden group flex flex-col justify-center
                "
              >
                <h4 class="font-bold text-black relative z-10">Weekly Progress Update</h4>
                <%= link_to new_course_project_progress_update_path(@course, @project), class: "text-center w-full bg-slate-600 hover:bg-slate-700 text-white text-sm font-bold py-2.5 px-4 rounded-xl transition-all shadow-md active:scale-[0.98] relative z-10 mt-4" do %>
                  Record New Progress Update
                <% end %>
              </div>
            <% end %>
            <section>
              <div>
                <%= render "progress_updates",
                progress_updates: @progress_updates,
                progress: @progress,
                project: @project,
                current_version: @current_version,
                latest_version: @latest_version,
                course: @course,
                weeks: @weeks %>
              </div>
            </section>
          </div>
        </div>

        <div
          data-mobile-tabs-target="commentsPanel"
          class="
            w-full min-[1245px]:w-[450px] flex-shrink-0 space-y-6 order-2 hidden
            min-[1245px]:block
          "
        >
          <div class="space-y-2 md:space-y-6">

            <div class="flex flex-col md:flex-row min-[1245px]:flex-col gap-4 md:gap-6">

              <%# -- DESKTOP-ONLY ACTIONS -- %>
              <% if (policy(@project).update? && !current_user.is_staff) || @current_version != @latest_version %>
                <section
                  class="
                    hidden min-[1245px]:block bg-white rounded-2xl shadow-sm border border-gray-100
                    p-5 flex-1
                  "
                >
                  <h4
                    class="
                      text-xs font-bold text-gray-400 uppercase tracking-wider mb-4 flex items-center
                      gap-2
                    "
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13 10V3L4 14h7v7l9-11h-7z"
                      /></svg>
                    Actions
                  </h4>
                  <%= render "project_actions",
                  members: @members,
                  current_user: current_user,
                  project: @project,
                  current_version: @current_version,
                  latest_version: @latest_version,
                  course: @course %>
                </section>
              <% end %>

              <%# -- DESKTOP-ONLY PROGRESS UPDATE CARD (Hidden on mobile) -- %>
              <% if policy(@project).can_record_progress_update? && @current_version == @latest_version %>
                <div
                  class="
                    hidden min-[1245px]:flex bg-gray-50 rounded-2xl p-6 border border-blue-100
                    shadow-sm relative overflow-hidden group flex-1 flex-col justify-center
                  "
                >
                  <h4 class="font-bold text-black relative z-10">Weekly Progress Update</h4>
                  <%= link_to new_course_project_progress_update_path(@course, @project), class: "text-center w-full bg-slate-600 hover:bg-slate-700 text-white text-sm font-bold py-2.5 px-4 rounded-xl transition-all shadow-md active:scale-[0.98] relative z-10 mt-4" do %>
                    Record New Progress Update
                  <% end %>
                </div>
              <% end %>
            </div>

            <div
              class="
                h-[600px] min-[1245px]:h-[700px] min-[1245px]:max-h-[calc(100vh-200px)]
              "
            >
              <%= render "project_comments",
              comments: @comments,
              new_comment: @new_comment,
              course: @course,
              project: @project,
              current_instance_id: @current_instance.id,
              current_version: @current_version,
              latest_version: @latest_version %>
            </div>

          </div>
        </div>

      </div>
    </div>

    <div class="flex items-center justify-center mt-4 sm:mt-6">
      <%= link_to course_path(@course), class: "group flex items-center text-sm font-medium text-gray-500 hover:text-green-600 transition-colors" do %>
        <div
          class="
            w-8 h-8 rounded-full bg-white border border-gray-200 flex items-center
            justify-center mr-2 group-hover:border-green-300 shadow-sm transition-all
          "
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            /></svg>
        </div>
        Back to Course
      <% end %>
    </div>

  </div>
</main>
