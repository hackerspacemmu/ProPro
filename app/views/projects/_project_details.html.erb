<% require "htmldiff" %>
<div class="w-full space-y-8">
  <div
    class="
      bg-white rounded-xl divide-y divide-gray-100 border border-gray-100 shadow-sm
      overflow-hidden
    "
  >
    <% fields.each do |field| %>

      <div
        class="
          flex flex-col sm:grid sm:grid-cols-[130px_1fr] md:grid-cols-3 group
          hover:bg-gray-50/50 transition-colors
        "
      >

        <%# Field Label %>
        <div
          class="
            px-4 py-3 sm:p-4 md:p-6 sm:col-span-1 !bg-gray-50/30 border-b sm:border-b-0
            sm:border-r border-gray-100 flex items-center sm:items-start
          "
        >
          <h4
            class="
              text-xs md:text-sm font-bold text-gray-700 uppercase tracking-wide
              leading-relaxed break-words
            "
          >
            <%= field.project_template_field.label %>
          </h4>
        </div>

        <%# Field value calculation (pre-calculated to prevent whitespace issues) %>
        <% display_text = nil
        is_markdown = false

        if field.value.present?
          if field.project_template_field.dropdown? ||
               field.project_template_field.radio?
            begin
              parsed = JSON.parse(field.value)
              display_text = parsed.is_a?(Array) ? parsed.join(", ") : parsed
            rescue JSON::ParserError
              display_text = field.value
            end
          elsif field.project_template_field.textarea?
            display_text = field.value
            is_markdown = true
          else
            display_text = field.value
          end
          display_text = display_text.to_s.strip
        end %>

        <%# Field value container %>
        <div
          class="
            !p-4 !md:p-6 sm:col-span-1 md:col-span-2 text-gray-900 break-words text-base
            md:text-lg font-medium leading-relaxed min-w-0 !bg-white
            <%= is_markdown ? 'prose prose-sm max-w-none' : 'whitespace-pre-wrap' %>
          "
        ><% if display_text.present? %><%= is_markdown ? render_markdown(display_text) : display_text %><% else %><span class="text-gray-400 italic font-normal text-base md:text-lg">No content provided</span><% end %></div>
      </div>
    <% end %>

    <div
      class="
        bg-gray-50/80 p-4 text-xs text-gray-500 font-medium border-t border-gray-100
        flex items-center gap-2
      "
    >
      <svg
        class="w-4 h-4 text-gray-400"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        /></svg>
      Based on Topic:
      <span class="text-gray-700 font-semibold"><%= based_on_topic_name || "Own Proposal" %></span>
    </div>
  </div>

  <%# --- VERSION DIFF COMPARISON --- %>
  <% if index < instances.size %>
    <div class="mt-8">

      <div class="flex items-center gap-3 mb-4">
        <h4 class="text-lg font-bold text-gray-800">Version Changes</h4>
        <span
          class="
            px-2.5 py-0.5 rounded-full bg-orange-100 text-orange-700 text-xs font-bold
            border border-orange-200
          "
        >
          Comparing v<%= index %>
          vs v<%= index + 1 %>
        </span>
      </div>

      <div
        class="
          bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden
        "
      >
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse table-fixed">
            <thead>
              <tr
                class="
                  bg-gray-50 border-b border-gray-200 text-sm uppercase tracking-wide
                  text-gray-500 font-semibold
                "
              >
                <th class="p-3 w-48 border-r border-gray-200">Field</th>
                <th class="p-3 w-1/2 border-r border-gray-200 bg-red-50/30 text-red-800">Deletions (Old)</th>
                <th class="p-3 w-1/2 bg-green-50/30 text-green-800">Additions (New)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">

              <% fields.zip(next_fields).each do |current_field, next_field| %>
                <% field_name = (current_field || next_field).project_template_field.label %>

                <% normalize = ->(text) do
                  text.to_s.gsub(/\r\n?/, "\n").gsub(/^$/, "[[EMPTYLINE]]")
                end %>

                <% clean_display = ->(text) do
                  if text.to_s.strip == "[[EMPTYLINE]]"
                    "&nbsp;".html_safe
                  else
                    text.to_s.gsub("[[EMPTYLINE]]", "")
                  end
                end %>

                <% old_val = normalize.call(current_field&.value) %>
                <% new_val = normalize.call(next_field&.value) %>

                <% if old_val != new_val %>
                  <tr class="bg-white group hover:bg-gray-50/20 transition-colors">
                    <td
                      class="
                        p-3 text-lg font-bold text-gray-700 align-top border-r border-gray-200
                        bg-gray-50/30 w-1/5
                      "
                    >
                      <%= field_name %>
                    </td>

                    <% raw_old = render_markdown(current_field&.value.to_s)
                    raw_new = render_markdown(next_field&.value.to_s)

                    # 2. Identity Branding: Brand the <li> tags before Nokogiri destroys the wrappers
                    brand_lists = ->(html) do
                      html =
                        html
                          .to_s
                          .gsub(%r{<ol[^>]*>.*?</ol>}m) do |m|
                            m.gsub(/<li\b[^>]*>/i, '<li class="diff-ol-item">')
                          end
                      html.gsub(%r{<ul[^>]*>.*?</ul>}m) do |m|
                        m.gsub(/<li\b[^>]*>/i, '<li class="diff-ul-item">')
                      end
                    end

                    old_html = brand_lists.call(raw_old)
                    new_html = brand_lists.call(raw_new)

                    html_differ = Object.new.extend(HTMLDiff)
                    rich_diff = html_differ.diff(old_html, new_html)

                    #  LEFT SIDE: Erase additions, sweep up empty wrappers, color deleted markers
                    left_html =
                      rich_diff
                        .gsub(%r{<ins\b[^>]*>.*?</ins>}m, "")
                        .gsub(%r{<li\b[^>]*>\s*</li>}m, "")
                        .gsub(%r{<(ul|ol)>\s*</\1>}m, "")
                        .gsub(%r{<p>\s*</p>}m, "")
                        .gsub(
                          %r{(<li\b[^>]*>)(\s*<del\b[^>]*>.*?</del>\s*)</li>}m,
                          '\1\2</li>', # Preserves the branded li tag
                        )
                        .gsub(%r{<(td|th)[^>]*>\s*</\1>}m, "")
                        .gsub(%r{<tr[^>]*>\s*</tr>}m, "")
                        .gsub(%r{<(thead|tbody)[^>]*>\s*</\1>}m, "")
                        .gsub(%r{<table[^>]*>\s*</table>}m, "")

                    #  RIGHT SIDE: Erase deletions, sweep up empty wrappers, color added markers
                    right_html =
                      rich_diff
                        .gsub(%r{<del\b[^>]*>.*?</del>}m, "")
                        .gsub(%r{<li\b[^>]*>\s*</li>}m, "")
                        .gsub(%r{<(ul|ol)>\s*</\1>}m, "")
                        .gsub(%r{<p>\s*</p>}m, "")
                        .gsub(
                          %r{(<li\b[^>]*>)(\s*<ins\b[^>]*>.*?</ins>\s*)</li>}m,
                          '\1\2</li>', # Preserves the branded li tag
                        )
                        .gsub(%r{<(td|th)[^>]*>\s*</\1>}m, "")
                        .gsub(%r{<tr[^>]*>\s*</tr>}m, "")
                        .gsub(%r{<(thead|tbody)[^>]*>\s*</\1>}m, "")
                        .gsub(%r{<table[^>]*>\s*</table>}m, "") %>

                    <%# LEFT SIDE: Deletions (Old) %>
                    <td
                      class="
                        p-4 align-top bg-red-50/10 w-2/5 border-r border-gray-200 break-words
                      "
                    >
                      <div
                        class="
                          w-full prose prose-sm max-w-none text-base [&_del]:bg-red-200
                          [&_del]:text-red-900 [&_del]:line-through [&_del]:decoration-red-400
                          [&_del]:decoration-2 [&_li.diff-ol-item]:list-decimal [&_li.diff-ol-item]:ml-6
                          [&_li.diff-ol-item::marker]:text-red-700 [&_li.diff-ol-item::marker]:font-bold
                          [&_li.diff-ul-item]:list-disc [&_li.diff-ul-item]:ml-6
                          [&_li.diff-ul-item::marker]:text-red-700 [&_li.diff-ul-item::marker]:font-bold
                        "
                      >
                        <%= sanitize left_html,
                        tags: %w[
                          h1
                          h2
                          h3
                          h4
                          h5
                          h6
                          p
                          br
                          ul
                          ol
                          li
                          strong
                          em
                          del
                          ins
                          table
                          thead
                          tbody
                          tr
                          th
                          td
                          blockquote
                          pre
                          code
                          a
                          img
                          hr
                        ],
                        attributes: %w[href src class alt title] %>
                      </div>
                    </td>

                    <%# RIGHT SIDE: Additions (New) %>
                    <td class="p-4 align-top bg-green-50/10 w-2/5 break-words">
                      <div
                        class="
                          w-full prose prose-sm max-w-none text-base [&_ins]:bg-green-200
                          [&_ins]:text-green-900 [&_ins]:font-medium [&_ins]:no-underline
                          [&_li.diff-ol-item]:list-decimal [&_li.diff-ol-item]:ml-6
                          [&_li.diff-ol-item::marker]:text-green-700 [&_li.diff-ol-item::marker]:font-bold
                          [&_li.diff-ul-item]:list-disc [&_li.diff-ul-item]:ml-6
                          [&_li.diff-ul-item::marker]:text-green-700 [&_li.diff-ul-item::marker]:font-bold
                        "
                      >
                        <%= sanitize right_html,
                        tags: %w[
                          h1
                          h2
                          h3
                          h4
                          h5
                          h6
                          p
                          br
                          ul
                          ol
                          li
                          strong
                          em
                          del
                          ins
                          table
                          thead
                          tbody
                          tr
                          th
                          td
                          blockquote
                          pre
                          code
                          a
                          img
                          hr
                        ],
                        attributes: %w[href src class alt title] %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>
