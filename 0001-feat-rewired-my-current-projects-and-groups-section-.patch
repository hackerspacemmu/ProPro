diff --git a/app/views/project_groups/_my_group_panel.html.erb b/app/views/project_groups/_my_group_panel.html.erb
new file mode 100644
index 0000000..07706a1
--- /dev/null
+++ b/app/views/project_groups/_my_group_panel.html.erb
@@ -0,0 +1,159 @@
+<%# Hide entirely for coordinators / lecturers %>
+<% unless @current_user_enrolment&.coordinator? || @current_user_enrolment&.lecturer? %>
+
+  <% if @my_group.nil? %>
+    <%# ── STATE A: Not in a group — styling TODO %>
+
+  <% else %>
+    <%# ── STATE B: In a group ── %>
+    <%
+      am_leader    = @my_group.leader_id == current_user.id
+      is_confirmed = @my_group.confirmed?
+      is_locked    = @my_group.locked?
+      member_count = @my_group.project_group_members.size
+      can_confirm  = @my_group.can_confirm?
+      window_open  = @course.grouping_window_open?
+    %>
+
+    <div class="border-2 border-gray-300 rounded-[3px] bg-white mb-6" data-testid="my-group-panel-grouped">
+
+      <%# ── Full width header %>
+      <div class="flex items-start justify-between px-5 py-4 border-b border-gray-200">
+        <div>
+          <div class="flex items-center gap-3 mb-2">
+            <div class="w-7 h-7 rounded-full bg-gray-200 shrink-0"></div>
+            <h2 class="text-xl font-bold text-gray-900"><%= @my_group.group_name %></h2>
+
+            <% if is_confirmed %>
+              <span class="inline-block bg-[#1F78D1] text-white text-[0.6875rem] font-normal rounded tracking-[1px] leading-none px-[0.625em] py-[0.4375em] whitespace-nowrap">
+                Confirmed
+              </span>
+            <% else %>
+              <span class="inline-block bg-[#475D65] text-white text-[0.6875rem] font-normal rounded tracking-[1px] leading-none px-[0.625em] py-[0.4375em] whitespace-nowrap">
+                Draft
+              </span>
+            <% end %>
+
+            <% if is_locked %>
+              <span class="inline-block">
+                <svg xmlns="http://www.w3.org/2000/svg" height="16px" viewBox="0 -960 960 960" width="16px" fill="currentColor" class="inline-block align-middle">
+                  <path d="M240-80q-33 0-56.5-23.5T160-160v-400q0-33 23.5-56.5T240-640h40v-80q0-83 58.5-141.5T480-920q83 0 141.5 58.5T680-720v80h40q33 0 56.5 23.5T800-560v400q0 33-23.5 56.5T720-80H240Zm0-80h480v-400H240v400Zm296.5-143.5Q560-327 560-360t-23.5-56.5Q513-440 480-440t-56.5 23.5Q400-393 400-360t23.5 56.5Q447-280 480-280t56.5-23.5ZM360-640h240v-80q0-50-35-85t-85-35q-50 0-85 35t-35 85v80ZM240-160v-400 400Z"/>
+                </svg>
+              </span>
+            <% end %>
+          </div>
+          <p class="text-xs text-gray-400"><%= member_count %> / <%= @course.group_max %> members</p>
+        </div>
+
+        <%# Dissolve — leader only, draft only %>
+        <% if am_leader && !is_confirmed && window_open %>
+          <%= button_to "Dissolve group",
+                course_project_group_path(@course, @my_group),
+                method: :delete,
+                class: "text-xs font-medium text-red-500 border border-red-200 rounded px-2.5 py-1 hover:bg-red-50 transition-colors shrink-0 mt-1",
+                form: { data: { confirm: "Dissolve this group? This cannot be undone." } } %>
+        <% end %>
+      </div>
+
+      <%# ── Three columns %>
+      <div class="block md:flex divide-y md:divide-y-0 md:divide-x divide-gray-200">
+
+        <%# ── Col 1: Settings %>
+        <div class="w-full md:w-48 shrink-0 p-4">
+          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">Settings</p>
+
+          <div class="flex flex-col gap-1.5">
+            <% if am_leader && !is_confirmed && window_open %>
+              <%= button_to "Confirm Group",
+                    confirm_course_project_group_path(@course, @my_group),
+                    method: :patch,
+                    disabled: !can_confirm,
+                    class: "w-full px-3 py-1.5 text-xs font-semibold text-white bg-[#1F78D1] rounded-[3px] hover:bg-[#1a6abf] transition-colors text-left disabled:opacity-40 disabled:cursor-not-allowed",
+                    title: can_confirm ? nil : "Group needs #{@course.group_min}–#{@course.group_max} members to confirm" %>
+            <% end %>
+
+            <% if am_leader && is_confirmed && window_open %>
+              <%= button_to "Revert to Draft",
+                    revert_course_project_group_path(@course, @my_group),
+                    method: :patch,
+                    class: "w-full px-3 py-1.5 text-xs font-medium text-gray-600 border border-gray-300 rounded-[3px] hover:border-gray-400 hover:text-gray-800 transition-colors text-left",
+                    form: { data: { confirm: "Revert to draft? You will lose confirmed status." } } %>
+            <% end %>
+
+            <% if am_leader && !is_confirmed && window_open %>
+              <% if is_locked %>
+                <%= button_to "Unlock Group",
+                      unlock_course_project_group_path(@course, @my_group),
+                      method: :patch,
+                      class: "w-full px-3 py-1.5 text-xs font-medium text-gray-600 border border-gray-300 rounded-[3px] hover:border-gray-400 hover:text-gray-800 transition-colors text-left" %>
+              <% else %>
+                <%= button_to "Lock Group",
+                      lock_course_project_group_path(@course, @my_group),
+                      method: :patch,
+                      class: "w-full px-3 py-1.5 text-xs font-medium text-gray-600 border border-gray-300 rounded-[3px] hover:border-gray-400 hover:text-gray-800 transition-colors text-left" %>
+              <% end %>
+            <% end %>
+          </div>
+
+          <div class="mt-4 pt-3 border-t border-gray-100">
+            <%# Leave group — Person 2 %>
+            <button disabled class="text-xs text-gray-400 hover:text-gray-600 transition-colors opacity-40 cursor-not-allowed">
+              Leave group
+            </button>
+          </div>
+        </div>
+
+        <%# ── Col 2: Members %>
+        <div class="flex-1 min-w-0 p-4">
+          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">Members</p>
+          <ul class="space-y-0 divide-y divide-gray-100">
+            <% @my_group.project_group_members.each do |membership| %>
+              <% member = membership.user %>
+              <% is_this_leader = member.id == @my_group.leader_id %>
+
+              <li class="flex items-center justify-between py-2 first:pt-0" data-testid="member-row-<%= member.id %>">
+                <div class="flex items-center gap-2.5">
+                  <div class="w-6 h-6 rounded-full bg-gray-200 shrink-0"></div>
+                  <span class="text-sm text-gray-800"><%= member.name %></span>
+                  <% if is_this_leader %>
+                    <span class="text-xs text-gray-400">(leader)</span>
+                  <% end %>
+                </div>
+
+                <% if am_leader && !is_this_leader && !is_confirmed && window_open %>
+                  <div class="flex items-center gap-3 shrink-0">
+                    <%= button_to promote_leader_course_project_group_path(@course, @my_group),
+                          method: :patch,
+                          params: { user_id: member.id },
+                          class: "text-xs text-gray-400 hover:text-gray-600 transition-colors",
+                          form: { data: { confirm: "Make #{member.name} the group leader? You will lose leader privileges." } } do %>
+                      Promote
+                    <% end %>
+
+                    <%= button_to course_project_group_member_path(@course, @my_group, member),
+                          method: :delete,
+                          class: "text-xs text-red-400 hover:text-red-600 transition-colors",
+                          form: { data: { confirm: "Remove #{member.name} from the group?" } } do %>
+                      Kick
+                    <% end %>
+                  </div>
+                <% end %>
+              </li>
+            <% end %>
+          </ul>
+        </div>
+
+        <%# ── Col 3: Join Requests — Person 3 wires this %>
+        <div class="w-full md:w-80 shrink-0 p-4">
+          <p class="text-[10px] font-semibold tracking-widest uppercase text-gray-400 mb-3">
+            Join Requests
+          </p>
+          <p class="text-xs text-gray-400">No pending requests</p>
+        </div>
+
+      </div>
+    </div>
+
+  <% end %>
+
+<% end %>
